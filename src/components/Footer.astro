---
const links = [
  { href: "/", label: "ACCUEIL" },
  { href: "/a-propos", label: "À PROPOS" },
  { href: "/services", label: "SERVICES" },
  { href: "/processus", label: "PROCESSUS" },
  { href: "/portfolio", label: "PORTFOLIO" },
  { href: "/boutique", label: "BOUTIQUE" },
  { href: "/contact", label: "CONTACT" },
];

const galleryStrip = [
  { src: "/images/footer-1.jpg", alt: "Salle de réception décorée" },
  { src: "/images/footer-2.jpg", alt: "Composition florale rouge" },
  { src: "/images/footer-3.jpg", alt: "Couple de mariés" },
  { src: "/images/footer-4.jpg", alt: "Domaine de réception" },
];
---

<footer class="bg-[#1a1a1a] text-white">
  <div class="mx-auto max-w-[1500px] px-8 lg:px-14 pt-20 pb-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {galleryStrip.map((img) => (
        <a href="/portfolio" class="block aspect-[3/4] overflow-hidden bg-neutral-800 group">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            onerror="this.style.background='linear-gradient(135deg,#2a2a2a,#1a1a1a)';this.removeAttribute('src');"
          />
        </a>
      ))}
    </div>

    <div class="mt-16 grid md:grid-cols-3 items-center gap-10">
      <a href="/" class="flex flex-col items-center md:items-start gap-1 select-none">
        <span class="font-script text-5xl text-white/40 -mb-3 -ml-1">AD</span>
        <span class="font-display tracking-[0.32em] text-xl uppercase">Aritia Design</span>
        <span class="text-[0.6rem] tracking-[0.45em] uppercase text-white/60">Event Designer</span>
      </a>

      <p class="font-italic-serif text-[0.95rem] text-white/85 leading-relaxed text-center max-w-lg mx-auto">
        Créatrice d'univers évènementiels haut de gamme, sur-mesure<br />
        à Toulouse, en haute-Garonne et ses alentours
      </p>

      <div class="flex flex-col items-center md:items-end gap-3">
        <span class="text-[0.7rem] tracking-[0.32em] uppercase">Suivez-nous</span>
        <a
          href="https://www.instagram.com/"
          aria-label="Instagram"
          class="inline-flex items-center justify-center w-10 h-10 rounded-md border border-white/40 hover:bg-white/10 transition"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="3" y="3" width="18" height="18" rx="4" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
          </svg>
        </a>
      </div>
    </div>

    <nav aria-label="Pied de page" class="mt-14">
      <ul class="flex flex-wrap justify-center gap-x-9 gap-y-3 text-[0.7rem] tracking-[0.28em] uppercase text-white/85">
        {links.map((l, i) => (
          <li>
            <a
              href={l.href}
              class:list={[
                "hover:text-white transition",
                i === 0 ? "underline underline-offset-[6px] decoration-white/60" : "",
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto max-w-[1500px] px-8 lg:px-14 py-5 flex flex-col md:flex-row items-center justify-between gap-2 text-[0.65rem] tracking-[0.18em] uppercase text-white/50">
      <span>Images &amp; vidéos crédits : RNT Motion, Stephen Meslin</span>
      <button
        type="button"
        onclick="window.scrollTo({top:0,behavior:'smooth'})"
        aria-label="Retour en haut"
        class="hidden md:inline-flex absolute right-10 -mt-16 w-10 h-10 items-center justify-center text-white/70 hover:text-white"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
          <path d="M12 19V5M5 12l7-7 7 7" />
        </svg>
      </button>
      <span>© Aritia Design 2025</span>
    </div>
  </div>
</footer>
