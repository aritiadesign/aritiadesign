---
import { navLinks as links } from "../data/nav";

interface Props {
  /** When false, render footer in light theme (white bg, dark text). */
  dark?: boolean;
}
const { dark = true } = Astro.props;

const galleryStripDark = [
  { src: "/images/footer-1.jpg", alt: "Salle de réception décorée" },
  { src: "/images/footer-2.jpg", alt: "Composition florale rouge" },
  { src: "/images/footer-3.jpg", alt: "Couple de mariés" },
  { src: "/images/footer-4.jpg", alt: "Domaine de réception" },
];
const galleryStripLight = [
  { src: "/images/footer-light-1.jpg", alt: "Décor de table d'honneur" },
  { src: "/images/footer-light-2.jpg", alt: "Composition florale détail" },
  { src: "/images/footer-light-3.jpg", alt: "Domaine et voiture vintage" },
  { src: "/images/footer-light-4.jpg", alt: "Salle de réception" },
];
const galleryStrip = dark ? galleryStripDark : galleryStripLight;
---

<footer class:list={[dark ? "bg-[#1a1a1a] text-white" : "bg-white text-[var(--color-ink)]"]} data-footer-theme={dark ? "dark" : "light"}>
  <div class="mx-auto max-w-[1500px] px-4 sm:px-8 lg:px-14 pt-28 md:pt-32 pb-0">
    <div class="mx-auto max-w-[1240px] grid grid-cols-2 lg:grid-cols-4 justify-center gap-4 md:gap-6">
      {galleryStrip.map((img) => (
        <a href="/portfolio" class="block aspect-square overflow-hidden bg-neutral-800 group">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            onerror="this.style.background='linear-gradient(135deg,#2a2a2a,#1a1a1a)';this.removeAttribute('src');"
          />
        </a>
      ))}
    </div>

    <div class="mt-16 mx-auto max-w-[1240px] grid lg:grid-cols-[auto_1fr_auto] items-center gap-14 lg:gap-10">
      <a
        href="/"
        class="relative inline-flex items-center justify-self-center lg:justify-self-start select-none text-white"
        aria-label="Aritia Design — Accueil"
        data-i18n-attr="aria-label:header.logo.aria"
      >
        <svg
          viewBox="164.805 324.211 1654.497 1024.949"
