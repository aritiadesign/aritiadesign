---
interface Props {
  /** Background image URL */
  image: string;
  /** Optional mobile (< 768px) override for the background image */
  imageMobile?: string;
  /** Alt text for the background */
  imageAlt?: string;
  /** Script-font main title */
  title?: string;
  /** Raw HTML title (allows <br /> for multiline) */
  titleHtml?: string;
  /** Optional uppercase subtitle */
  subtitle?: string;
  /** Pass through raw HTML for the subtitle (e.g. with <br />) */
  subtitleHtml?: string;
  /** Override the script title font-size on desktop. */
  titleSizeMd?: string;
  /** Override the script title font-size on mobile. */
  titleSizeMobile?: string;
}

const {
  image,
  imageMobile,
  imageAlt = "",
  title,
  titleHtml,
  subtitle,
  subtitleHtml,
  titleSizeMd = "124px",
  titleSizeMobile = "56px",
} = Astro.props;
---

<section
  class="page-hero-section relative h-screen min-h-[560px] w-full overflow-hidden text-white"
  style={`--hero-bg: url('${image}'); --hero-bg-mobile: url('${imageMobile ?? image}');`}
  aria-label={imageAlt}
>
  <div class="absolute inset-0 bg-black/40"></div>

  <div class="page-hero-content relative h-full flex flex-col items-center justify-end text-center px-6">
    <h1
      class="font-script text-white leading-none inline-block"
      style={`font-size: clamp(${titleSizeMobile}, 10vw, ${titleSizeMd}); transform: rotate(-9deg);`}
    >
      {titleHtml ? <Fragment set:html={titleHtml} /> : title}
    </h1>

    <span class="page-hero-rule" aria-hidden="true"></span>

    {(subtitleHtml || subtitle) && (
      <p class="mt-6 md:mt-10 text-[12px] sm:text-[13px] md:text-[15px] tracking-[1.6px] sm:tracking-[2px] md:tracking-[2.25px] uppercase text-white/85 max-w-2xl">
        {subtitleHtml ? <Fragment set:html={subtitleHtml} /> : subtitle}
      </p>
    )}
  </div>
</section>

<style>
  .page-hero-section {
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }
  /* iOS Safari mishandles background-attachment: fixed (zooms image to the full scrollable area).
     Force scroll on mobile so the image fits the viewport like everywhere else.
     We also swap to the mobile-specific image if one was provided. */
  @media (max-width: 767px) {
    .page-hero-section {
      background-image: var(--hero-bg-mobile);
      background-attachment: scroll;
    }
  }
  .page-hero-content {
    padding-bottom: 8rem;
  }
  .page-hero-rule {
    display: block;
    width: 35px;
    height: 1px;
    background-color: #fff;
    margin-top: 2.5rem;
  }
  @media (min-width: 768px) {
    .page-hero-rule { margin-top: 4rem; }
  }
  /* On mobile, drop the hard-coded line breaks in the subtitle so the text
     reflows naturally and never exceeds 3 lines on narrow viewports.
     Exception: <br class="show-mobile"> stays visible on mobile (used to
     force a specific break point that we also want on desktop). */
  @media (max-width: 767px) {
    .page-hero-content p :global(br) { display: none; }
    .page-hero-content p :global(br.show-mobile) { display: inline; }
  }
</style>
