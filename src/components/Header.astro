---
import Logo from "./Logo.astro";
import LangToggle from "./LangToggle.astro";

interface Props {
  transparent?: boolean;
}
const { transparent = true } = Astro.props;

import { navLinks as links } from "../data/nav";

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);
---

<header
  class:list={[
    "absolute top-0 inset-x-0 z-50",
    transparent ? "bg-transparent text-white" : "bg-white text-[var(--color-ink)]",
  ]}
  data-site-header
>
  <div class="mx-auto max-w-[1500px] px-4 sm:px-6 lg:px-14 pt-[25px] pb-4 flex items-center justify-between">
    <a href="/" class="flex items-center group" aria-label="Aritia Design — Accueil" data-i18n-attr="aria-label:header.logo.aria">
      <Logo class="w-[200px] sm:w-[240px] md:w-[280px] xl:w-[415px] h-auto" />
    </a>

    <nav aria-label="Principal" class="hidden xl:block">
      <ul class="flex items-center gap-6 text-[12px] leading-[1.7] tracking-[0.2em] uppercase font-normal">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="relative inline-block leading-none nav-link"
              data-active={isActive(l.href)}
            >
              <span data-i18n={l.key}>{l.label}</span>
              <span class="understrike" aria-hidden="true"></span>
            </a>
          </li>
        ))}
        <li class="flex items-center pl-6 border-l border-current/50">
          <LangToggle size="md" />
        </li>
      </ul>
    </nav>

    <button
      type="button"
      class="xl:hidden p-2 -mr-2"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-mobile-toggle
      data-i18n-attr="aria-label:header.mobile.open"
    >
      <svg class="burger" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
        <path d="M3 7h18M3 12h18M3 17h18" />
      </svg>
    </button>
  </div>
</header>

{/* Mobile drawer — full-screen overlay */}
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] bg-[#1a1a1a] text-white translate-x-full transition-transform duration-300 ease-out xl:hidden flex flex-col"
  data-mobile-menu
  aria-hidden="true"
>
  <button
    type="button"
    class="absolute top-8 right-4 p-2 z-10"
    aria-label="Fermer le menu"
    data-mobile-close
    data-i18n-attr="aria-label:header.mobile.close"
  >
    <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
      <path d="M6 6l12 12M18 6L6 18" />
    </svg>
  </button>

  <div class="flex-1 flex flex-col items-center justify-center px-6">
    <span class="font-display font-normal text-[2.2rem] uppercase !tracking-[0.8em]" data-i18n="header.mobile.menu">Menu</span>

  <nav aria-label="Mobile" class="flex flex-col items-center mt-4 gap-10">
    {links.map((l) => (
      <a
        href={l.href}
        class="font-[var(--font-brandon)] text-[14px] leading-[1.7] tracking-[0.2em] uppercase font-normal hover:opacity-70 transition"
        data-active={isActive(l.href)}
        data-i18n={l.key}
      >
        {l.label}
      </a>
    ))}
    <LangToggle size="lg" variant="flag" class="mt-4" />
  </nav>
  </div>
</div>

<script>
  // Mobile drawer open/close
  const toggle = document.querySelector<HTMLButtonElement>("[data-mobile-toggle]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-mobile-close]");
  const menu = document.querySelector<HTMLElement>("[data-mobile-menu]");

  const setOpen = (open: boolean) => {
    if (!menu || !toggle) return;
    menu.classList.toggle("translate-x-full", !open);
    menu.setAttribute("aria-hidden", String(!open));
    toggle.setAttribute("aria-expanded", String(open));
    document.documentElement.style.overflow = open ? "hidden" : "";
  };

  toggle?.addEventListener("click", () => setOpen(true));
  closeBtn?.addEventListener("click", () => setOpen(false));

  // Close drawer on Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") setOpen(false);
  });

  // Close drawer when a nav link is clicked (so internal navigation feels snappy)
  menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setOpen(false)));
</script>

<style>
  .nav-link {
    display: inline-block;
  }

  .understrike {
    position: absolute;
    left: 0;
    bottom: -4px;
    height: 1px;
    width: 100%;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: right center;
    transition: transform 0.4s cubic-bezier(0.65, 0, 0.35, 1);
  }

  .nav-link[data-active="true"] .understrike,
  .nav-link:hover .understrike {
    transform: scaleX(1);
    transform-origin: left center;
  }
</style>
