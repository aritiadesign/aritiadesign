---
interface Props {
  href: string;
  label: string;
  /** Tailwind size of the arrow SVG, defaults to h-[37px] w-[37px] */
  arrowClass?: string;
  /** Extra classes for the wrapping <a> */
  class?: string;
}

const {
  href,
  label,
  arrowClass = "h-[37px] w-[37px]",
  class: extraClass = "",
} = Astro.props;
---

<a
  href={href}
  class:list={[
    "inline-flex items-center gap-3 text-[18px] leading-none tracking-[0.2em] uppercase hover:opacity-70 transition",
    extraClass,
  ]}
>
  <span class="text-current/80 inline-flex items-center leading-none">✦</span>
  <span class="leading-none">{label}</span>
  <svg
    aria-hidden="true"
    viewBox="0 0 200 200"
    fill="currentColor"
    class:list={["ml-1 shrink-0 -rotate-90", arrowClass]}
  >
    <path d="m144.401 135.073-.094-3.243c-.484.013-12.002.403-23.648 6.459a47.344 47.344 0 0 0-8.023 5.242c-3.719 3.024-9.343.355-9.343-4.393V20h-6.592v119.089c0 4.748-5.626 7.417-9.344 4.392a46.94 46.94 0 0 0-8.029-5.242c-11.649-6.04-23.17-6.397-23.654-6.408l-.174 6.486c.106.003 10.653.362 20.952 5.765 13.434 7.05 20.246 19.135 20.245 35.919h6.595c-.001-16.732 6.812-28.801 20.25-35.872 10.301-5.42 20.852-5.809 20.957-5.812l-.098-3.244z" />
  </svg>
</a>
