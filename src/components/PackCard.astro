---
import MediaCard from "./MediaCard.astro";

interface Props {
  title: string;
  italic?: string;
  label: string;
  bullets: string[];
  desc: string;
  image: string;
  accent?: "dark" | "burgundy";
  bgColor?: string;
  watermark?: string;
  imageAlt?: string;
  /** i18n key prefix; derives `${prefix}.title`, `.italic`, `.label`, `.desc`, `.b0..bN` */
  i18nPrefix?: string;
}

const {
  title,
  italic,
  label,
  bullets,
  desc,
  image,
  accent = "dark",
  bgColor,
  watermark,
  imageAlt,
  i18nPrefix,
} = Astro.props;
const k = (suffix: string) => (i18nPrefix ? `${i18nPrefix}.${suffix}` : undefined);
---

<MediaCard
  image={image}
  imageAlt={imageAlt ?? title}
  variant="flush"
  accent={accent}
  bgColor={bgColor}
  watermark={accent === "burgundy" ? undefined : watermark}
>
  <svg
    viewBox="164.805 324.211 1654.497 1024.949"
    preserveAspectRatio="xMidYMid meet"
