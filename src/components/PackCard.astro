    </g>
  </svg>
  <h3
    class:list={[
      "font-display font-normal leading-[1.1] tracking-wide whitespace-nowrap",
      title.includes("&")
        ? "text-[22px] md:text-[28px]"
        : "text-[28px] md:text-[36px]",
    ]}
    data-i18n={k("title")}
  >
    {title.split("&").map((part, i, arr) => (
      <>{part}{i < arr.length - 1 && <span class="amp">&amp;</span>}</>
    ))}
  </h3>
  {italic && (
    <p class="mt-2 font-italic-serif italic font-light text-[24px] md:text-[32px] leading-tight" data-i18n={k("italic")}>
      {italic}
    </p>
  )}
  <p class="mt-6 text-[14px] tracking-[0.28em] uppercase text-white" set:html={label} data-i18n={k("label")}></p>
  <p class="mt-8 text-[14px] tracking-[0.28em] uppercase text-white" data-i18n="services.packCard.included">
    Compris dans l'expérience
  </p>
  <ul class="mt-3 space-y-2 text-[16px] leading-[1.7] text-white">
    {bullets.map((b, idx) => (
      <li class="flex gap-3 items-start">
        <span aria-hidden="true" class="inline-block w-[7px] h-[7px] rounded-full bg-current mt-[11px] shrink-0"></span>
        <span data-i18n={k(`b${idx}`)}>{b}</span>
      </li>
    ))}
  </ul>
  <p class="mt-7 text-[16px] leading-[1.9] text-white max-w-md" data-i18n={k("desc")}>{desc}</p>
</MediaCard>
