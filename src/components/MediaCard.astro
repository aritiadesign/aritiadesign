---
interface Props {
  /** Image src */
  image: string;
  imageAlt?: string;
  /** Container accent. "dark" = #1A1A1A, "burgundy" = #640613 */
  accent?: "dark" | "burgundy";
  /** Override the accent background with a custom CSS color (e.g. "#2b2a2d") */
  bgColor?: string;
  /** Watermark image overlaid behind text (used on burgundy pack) */
  watermark?: string;
  /** Layout variant. "floating" = image has margin (tabs), "flush" = image edge-to-edge (packs) */
  variant?: "floating" | "flush";
  /** Aspect ratio on mobile (defaults to 4/3) */
  mobileAspect?: string;
  /** Fixed image width on md+ in px (floating only) */
  imageWidth?: number;
  /** Fixed image height on md+ in px (floating only) */
  imageHeight?: number;
}

const {
  image,
  imageAlt = "",
  accent = "dark",
  bgColor,
  watermark,
  variant = "floating",
  mobileAspect = "4/3",
  imageWidth = 518,
  imageHeight = 565,
} = Astro.props;

const bgClass = bgColor ? "" : accent === "burgundy" ? "bg-[#640613]" : "bg-[#1A1A1A]";
const bgStyle = bgColor ? `background-color: ${bgColor};` : "";
const isFlush = variant === "flush";
---

<article class:list={["media-card text-white overflow-hidden", bgClass, isFlush ? "" : "rounded-tr-lg rounded-b-lg"]} style={bgStyle}>
  <style>
    @media (min-width: 768px) {
      .media-card .media-card-img-floating {
        width: var(--mw);
        height: var(--mh);
        max-width: 100%;
      }
    }
  </style>

  <div
    class:list={[
      "grid md:grid-cols-2 items-stretch relative md:min-h-[680px]",
      isFlush ? "" : "gap-10 md:gap-14 p-8 md:p-14",
    ]}
  >
    {watermark && (
      <img
        src={watermark}
        alt=""
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 w-full h-full object-cover opacity-25"
      />
    )}
    <slot name="card-bg" />

    {/* image */}
    {isFlush ? (
      <div class={`relative aspect-[${mobileAspect}] md:aspect-auto overflow-hidden`}>
        <img src={image} alt={imageAlt} class="absolute inset-0 w-full h-full object-cover" />
        <slot name="image-overlay" />
      </div>
    ) : (
      <div
        class:list={["media-card-img-floating relative md:justify-self-center", `aspect-[${mobileAspect}]`, "md:aspect-auto"]}
        style={`--mw:${imageWidth}px;--mh:${imageHeight}px;`}
      >
        <div class="absolute inset-0 overflow-hidden">
          <img src={image} alt={imageAlt} class="absolute inset-0 w-full h-full object-cover" />
        </div>
        <slot name="image-overlay" />
      </div>
    )}

    {/* text */}
    <div
      class:list={[
        "relative flex flex-col",
        isFlush ? "p-8 md:p-14 justify-center" : "",
      ]}
    >
      <slot />
    </div>
  </div>
</article>
