<script>
  const carousel = document.querySelector<HTMLElement>("[data-testimonial-carousel]");
  const imageStack = document.querySelector<HTMLElement>("[data-testimonial-images]");
  if (carousel) {
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>(".testimonial-slide"));
    const images = imageStack
      ? Array.from(imageStack.querySelectorAll<HTMLImageElement>(".testimonial-image"))
      : [];
    const nextBtns = carousel.querySelectorAll<HTMLButtonElement>("[data-testimonial-next]");
    let current = 0;
    const show = (i: number) => {
      slides.forEach((s, idx) => {
        const active = idx === i;
        s.style.opacity = active ? "1" : "0";
        s.style.pointerEvents = active ? "auto" : "none";
        // Active slide stays in flow so the container auto-sizes to it;
        // the others are absolute-positioned overlays.
        if (active) {
          s.classList.remove("absolute", "inset-x-0", "top-0");
        } else {
          s.classList.add("absolute", "inset-x-0", "top-0");
        }
      });
      images.forEach((img, idx) => {
        img.style.opacity = idx === i ? "1" : "0";
      });
    };
    nextBtns.forEach((btn) =>
      btn.addEventListener("click", () => {
        current = (current + 1) % slides.length;
        show(current);
      })
    );
  }
</script>
