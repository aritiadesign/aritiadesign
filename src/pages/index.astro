---
import Layout from "../layouts/Layout.astro";
import SparkLink from "../components/SparkLink.astro";

// Portfolio strip — exact image order and per-image widths matching the
// Wix carousel. All source files are 1200×1600; widths below set the
// displayed container width (object-fit: cover crops each one).
const portfolioImages = [
  { src: "/images/portfolio-strip/01_3e933860.jpg", alt: "Salle de réception, lustres",        w: 620 },
  { src: "/images/portfolio-strip/02_74179fa8.jpg", alt: "Château + fontaine",                 w: 380 },
  { src: "/images/portfolio-strip/03_e633e2c6.jpg", alt: "Couple, costume sombre",             w: 380 },
  { src: "/images/portfolio-strip/04_6297cc8a.png", alt: "Centre de table fleuri",             w: 340 },
  { src: "/images/portfolio-strip/05_41e5ab48.jpg", alt: "Voiture jaune, bouquet",             w: 360 },
  { src: "/images/portfolio-strip/06_95d16cce.jpg", alt: "Entrée — lustre & marié",            w: 320 },
  { src: "/images/portfolio-strip/07_dce575f9.jpg", alt: "Table dressée, roses blanches",      w: 400 },
  { src: "/images/portfolio-strip/08_abe01ccb.jpg", alt: "Composition florale, église",        w: 320 },
  { src: "/images/portfolio-strip/09_06a401f7.jpg", alt: "Invitée, chapeau blanc",             w: 360 },
  { src: "/images/portfolio-strip/10_990a1165.jpg", alt: "Église, allée centrale",             w: 560 },
  { src: "/images/portfolio-strip/11_a37af623.jpg", alt: "Cérémonie laïque extérieure",        w: 620 },
  { src: "/images/portfolio-strip/12_4f08de47.jpg", alt: "Alliances, mains",                   w: 380 },
  { src: "/images/portfolio-strip/13_f97907ca.jpg", alt: "Mariée + bouquet",                   w: 320 },
  { src: "/images/portfolio-strip/14_b88c2457.jpg", alt: "Composition pampa, socle",           w: 320 },
  { src: "/images/portfolio-strip/15_9392a4cb.jpg", alt: "Réception, charpente bois",          w: 580 },
  { src: "/images/portfolio-strip/16_d03e2066.jpg", alt: "Salle longue, suspensions",          w: 460 },
  { src: "/images/portfolio-strip/17_f9bdf9b5.jpg", alt: "Couvert — menu & merci",             w: 360 },
];
---

<Layout
  title="Aritia Design — Wedding Designer & créatrice de mariages d'exception à Toulouse"
  description="Wedding designer à Toulouse. Aritia conçoit des mariages raffinés et événements haut de gamme — direction artistique, design floral, scénographie immersive et papeterie sur-mesure, en Haute-Garonne et alentours."
  transparentHeader={true}
>
  {/* ───────────────────────── 1. HERO ───────────────────────── */}
  <section
    class="relative h-screen min-h-[640px] w-full overflow-hidden text-white bg-center bg-cover bg-no-repeat"
    style="background-image: url('/images/hero-poster.jpg');"
  >
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/25"></div>

    <div class="relative h-full flex flex-col items-center justify-center md:justify-end text-center px-6 md:pb-[5%]">
      <h1 class="font-display font-normal text-white text-[26px] sm:text-[32px] md:text-[40px] leading-[1.35] md:leading-[52px] tracking-[0.05em]">
        DIRECTRICE ARTISTIQUE<br />
        DESIGNER FLORAL
        <span class="inline-block mx-2 md:mx-3 align-middle text-white/80 text-[14px] sm:text-[16px] md:text-[20px]">✦</span>
        SCÉNOGRAPHE<br />
        CRÉATRICE <span class="font-italic-serif italic font-normal">de</span> PAPETERIE
      </h1>
      <p class="mt-14 md:mt-16 text-[12px] sm:text-[13px] md:text-[15px] tracking-[0.16em] md:tracking-[2.25px] uppercase text-white/85 leading-[1.9]">
        Créatrice d'univers pour mariages &amp;<br />
        évènements d'exception
      </p>

    </div>
  </section>

  {/* ───────────────────────── 2. INTRO ───────────────────────── */}
  <section id="intro" class="bg-white py-20 md:py-28 px-6">
    <div class="mx-auto text-center max-w-[1100px]">
      <h2 class="font-display font-normal text-[2rem] sm:text-[2.4rem] md:text-[2.8rem] leading-tight tracking-wide">
        CRÉATRICE D'UNIVERS ÉVÈNEMENTIELS<br />HAUT DE GAMME
      </h2>
      <p class="mt-10 md:mt-14 text-[0.78rem] sm:text-[0.82rem] tracking-[0.18em] uppercase leading-[2.1] text-[var(--color-ink-soft)]">
        Aritia Design vous accompagne dans la conception de mariages<br />
        et évènements sur-mesure, raffinés et authentiques.<br />
        À Toulouse, comme partout en France.
      </p>
    </div>
  </section>

  {/* ───────────────────────── 3. PORTFOLIO STRIP (marquee) ───────────────── */}
  <section class="bg-[#1a1a1a] text-white relative overflow-hidden pt-[110px] pb-[110px]">
    {/* solid side bands of the portfolio section — overlay on top of the marquee */}
    <div class="pointer-events-none absolute inset-y-0 left-0 w-[110px] bg-[#1a1a1a] z-20"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-[110px] bg-[#1a1a1a] z-20"></div>

    {/* big PORTFOLIO heading — anchored at top, just inside the left dark band */}
    <h2
      class="font-display font-normal text-white leading-none tracking-[0.01em]
             text-[44px] md:text-[88px]
             absolute z-30 top-[35px] md:top-[49px] left-[170px]
             select-none pointer-events-none"
    >
      PORTFOLIO
    </h2>

    <div class="marquee relative w-full">
      <div class="marquee-track gap-[16px] md:gap-[20px] items-center">
        {[...portfolioImages, ...portfolioImages].map((img, i) => (
          <a
            href="/portfolio"
            class="shrink-0 block h-[320px] md:h-[480px] overflow-hidden bg-neutral-800 group"
            style={`width: ${img.w}px;`}
            aria-label={img.alt}
            tabindex={i < portfolioImages.length ? 0 : -1}
            aria-hidden={i >= portfolioImages.length ? "true" : undefined}
          >
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </a>
        ))}
      </div>
    </div>

    {/* VOIR GALLERY — centered in the bottom dark band so top/bottom gaps match */}
    <div class="absolute z-30 left-0 right-0 bottom-0 h-[110px] px-6 md:px-14 flex items-center justify-end">
      <SparkLink href="/portfolio" label="Voir Gallery" />
    </div>
  </section>

  {/* ───────────────────────── 4. MÉTHODE DE TRAVAIL ───────────────────────── */}
  <section class="bg-white px-6 pt-16 pb-[200px] md:pt-[140px] md:pb-[260px] overflow-x-hidden">
    <div class="mx-auto max-w-[1200px] grid md:grid-cols-2 gap-14 md:gap-20 items-center w-full">
      <div class="relative order-2 md:order-1">
        <div class="h-[400px] md:h-[480px] bg-cream overflow-hidden">
          <img
            src="/images/methode.jpg"
            alt="Voiture orange ornée de fleurs blanches"
            class="w-full h-full object-cover"
            onerror="this.style.background='linear-gradient(135deg,#e8d8c0,#c69d6a)';this.removeAttribute('src');"
          />
        </div>
        <p class="font-script text-[32px] md:text-[50px] leading-[1.1] text-[var(--color-ink)]/80 absolute right-2 md:-right-32 -bottom-[80px] md:-bottom-[135px] whitespace-nowrap text-center rotate-[-8deg]">
          Transformez chaque<br />occasion en<br />moment d'exception
        </p>
      </div>

      <div class="md:pl-6 text-center flex flex-col items-center order-1 md:order-2">
        <h2 class="font-display font-light text-[44px] md:text-[60px] leading-[1.1]">
          MÉTHODE<br />
          <span class="font-italic-serif italic">de</span> TRAVAIL
        </h2>
        <p class="mt-8 text-[16px] leading-[1.9] text-[var(--color-ink-soft)] max-w-md">
          De la première inspiration au jour J, je vous accompagne avec
          sensibilité et exigence dans la création d'un univers qui vous
          ressemble&nbsp;– une approche sur-mesure, pensée pour faire
          naître l'harmonie, la beauté et l'émotion.
        </p>
        <a
          href="/processus"
          class="inline-block mt-10 px-10 py-4 border border-[var(--color-ink)] text-[0.72rem] tracking-[0.32em] uppercase hover:bg-[var(--color-ink)] hover:text-white transition"
        >
          Découvrir
        </a>
      </div>
    </div>
  </section>

  {/* ───────────────────────── 5. MARIAGE / OCCASION SPÉCIALE ───────────────────────── */}
  <section class="bg-[#1a1a1a] text-white py-28 md:py-36 px-6">
    <div class="mx-auto max-w-[1200px] grid md:grid-cols-2 gap-14 md:gap-20 items-center">
      <div class="md:order-1 order-2 text-center flex flex-col items-center">
        <h2 class="font-display font-light text-[44px] md:text-[60px] leading-[1.1]">
          MARIAGE<br />
          <span class="font-italic-serif italic">Occasion Spéciale</span>
        </h2>
        <p class="mt-8 text-[16px] leading-[1.9] text-white/80 max-w-md">
          À travers une approche transversale mêlant design floral,
          scénographie immersive, papeterie personnalisée et identité
          visuelle, je conçois à vos côtés un univers esthétique global,
          où chaque choix incarne avec exigence l'essence de votre
          histoire&nbsp;– une alchimie subtile entre vos envies et ma
          vision du beau.
        </p>
        <a
          href="/services"
          class="inline-block mt-10 px-10 py-4 border border-white text-[0.72rem] tracking-[0.32em] uppercase hover:bg-white hover:text-[var(--color-ink)] transition"
        >
          Explorer
        </a>
      </div>

      <div class="md:order-2 order-1 aspect-[4/3] overflow-hidden">
        <img
          src="/images/mariage.jpg"
          alt="Salle de réception de mariage avec tables dressées"
          class="w-full h-full object-cover"
          onerror="this.style.background='linear-gradient(135deg,#3a3530,#1a1a1a)';this.removeAttribute('src');"
        />
      </div>
    </div>
  </section>

  {/* ───────────────────────── 6. MOSAÏQUE PHOTOS (desktop only) ───────────────────────── */}
  <section class="hidden md:block bg-white py-28 md:py-36 px-6">
    <div class="mx-auto max-w-[1100px] relative h-[540px] md:h-[640px]">
      <div class="absolute left-[6%] top-[18%] w-[26%] aspect-[3/4] overflow-hidden shadow-sm">
        <img
          src="/images/collage-1.jpg"
          alt="Salon classique avec lustre"
          class="w-full h-full object-cover"
          onerror="this.style.background='linear-gradient(135deg,#d8c9b3,#a8896a)';this.removeAttribute('src');"
        />
      </div>
      <div class="absolute left-[28%] top-0 w-[32%] aspect-[3/4] overflow-hidden shadow-sm">
        <img
          src="/images/collage-2.jpg"
          alt="Invitée au chapeau blanc"
          class="w-full h-full object-cover"
          onerror="this.style.background='linear-gradient(135deg,#1f2a3a,#0e1828)';this.removeAttribute('src');"
        />
      </div>
      <div class="absolute right-[8%] top-[26%] w-[28%] aspect-[4/3] overflow-hidden shadow-sm">
        <img
          src="/images/collage-3.jpg"
          alt="Domaine de réception avec fontaine"
          class="w-full h-full object-cover"
          onerror="this.style.background='linear-gradient(135deg,#6a8d59,#3a5a40)';this.removeAttribute('src');"
        />
      </div>
    </div>
  </section>

  {/* ───────────────────────── 7. TÉMOIGNAGE ───────────────────────── */}
  <section class="bg-white pb-28 md:pb-36 px-6">
    <div class="mx-auto max-w-[1100px] grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <div class="aspect-[3/4] overflow-hidden">
        <img
          src="/images/testimonial.jpg"
          alt="Mariée vue d'en haut dans l'escalier"
          class="w-full h-full object-cover"
          onerror="this.style.background='linear-gradient(135deg,#cfc1ad,#7a6a5a)';this.removeAttribute('src');"
        />
      </div>
      <figure class="md:pl-8 relative">
        <span class="font-italic-serif italic text-[5rem] leading-none text-black/15 absolute -left-2 -top-6 select-none">“</span>
        <blockquote class="font-italic-serif italic text-[1.6rem] md:text-[1.9rem] leading-[1.4] text-[var(--color-ink)]">
          Merci encore pour ce mariage qui était tout simplement magique&nbsp;!
          Tu as fait un travail remarquable en moins de 6 mois&nbsp;!
          Je recommande à 100&nbsp;%&nbsp;!
        </blockquote>
        <figcaption class="mt-8 text-[0.72rem] tracking-[0.32em] uppercase text-[var(--color-muted)]">
          — Mélodie &amp; Thibault
        </figcaption>
      </figure>
    </div>
  </section>

  {/* ───────────────────────── 8. À PROPOS (fond marbre noir) ───────────────────────── */}
  <section class="relative text-white overflow-hidden">
    {/* black marble background */}
    <div
      class="absolute inset-0 bg-[#0e0e0e]"
      style="background-image: url('/images/marble.jpg'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-black/40"></div>

    <div class="relative mx-auto max-w-[1300px] px-6 lg:px-14 py-28 md:py-36 grid md:grid-cols-2 gap-14 md:gap-20 items-center">
      {/* photo + script overlay */}
      <div class="relative">
        <div class="aspect-[5/4] overflow-hidden bg-neutral-800 shadow-xl">
          <img
            src="/images/aritia-portrait.jpg"
            alt="Aritia, fondatrice d'Aritia Design"
            class="w-full h-full object-cover"
          />
        </div>
        <p class="font-script absolute -bottom-12 md:-bottom-16 left-6 md:left-12 text-[2.4rem] md:text-[3.2rem] leading-[1] text-white/95 select-none rotate-[-4deg]">
          Allier le beau<br />
          <span class="ml-10 md:ml-16">à l'essentiel</span>
        </p>
      </div>

      {/* texte à droite */}
      <div class="md:pl-4 mt-16 md:mt-0">
        <h2 class="font-display font-light text-[44px] md:text-[60px] leading-none tracking-wide">
          À&nbsp;PROPOS
        </h2>

        <div class="mt-10 space-y-6 text-[16px] leading-[1.85] text-white/85 max-w-md">
          <p>
            Implantée en Haute-Garonne, Aritia Design accompagne une
            clientèle en quête d'expériences uniques, où l'esthétique
            et l'émotion occupent une place centrale.
          </p>
          <p>
            Formée au design et passionnée par l'art de sublimer
            l'instant, je développe un savoir-faire complet alliant
            minutie, création et mise en scène.
          </p>
        </div>

        <SparkLink href="/a-propos" label="En savoir plus" class="mt-12" />
      </div>
    </div>
  </section>

  {/* ───────────────────────── 9. CTA "ENSEMBLE…" ───────────────────────── */}
  <section class="bg-white py-24 md:py-32 px-6 text-center">
    <h2 class="font-display font-light text-[2rem] sm:text-[2.4rem] md:text-[2.8rem] leading-[1.2]">
      ENSEMBLE,<br />
      CRÉONS UNE ATMOSPHÈRE<br />
      QUI VOUS RESSEMBLE
    </h2>
    <a
      href="/contact"
      class="inline-block mt-12 px-12 py-4 bg-[var(--color-burgundy)] text-white text-[0.72rem] tracking-[0.32em] uppercase hover:bg-[var(--color-burgundy-dark)] transition"
    >
      Laissez un message
    </a>
  </section>
</Layout>
