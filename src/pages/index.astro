---
import Layout from "../layouts/Layout.astro";
import SparkLink from "../components/SparkLink.astro";

// Portfolio strip — exact image order and per-image widths matching the
// Wix carousel. All source files are 1200×1600; widths below set the
// displayed container width (object-fit: cover crops each one).
const portfolioImages = [
  { src: "/images/portfolio-strip/01_3e933860.jpg", alt: "Salle de réception, lustres",        w: 620 },
  { src: "/images/portfolio-strip/02_74179fa8.jpg", alt: "Château + fontaine",                 w: 380 },
  { src: "/images/portfolio-strip/03_e633e2c6.jpg", alt: "Couple, costume sombre",             w: 380 },
  { src: "/images/portfolio-strip/04_6297cc8a.png", alt: "Centre de table fleuri",             w: 340 },
  { src: "/images/portfolio-strip/05_41e5ab48.jpg", alt: "Voiture jaune, bouquet",             w: 360 },
  { src: "/images/portfolio-strip/06_95d16cce.jpg", alt: "Entrée — lustre & marié",            w: 320 },
  { src: "/images/portfolio-strip/07_dce575f9.jpg", alt: "Table dressée, roses blanches",      w: 400 },
  { src: "/images/portfolio-strip/08_abe01ccb.jpg", alt: "Composition florale, église",        w: 320 },
  { src: "/images/portfolio-strip/09_06a401f7.jpg", alt: "Invitée, chapeau blanc",             w: 360 },
  { src: "/images/portfolio-strip/10_990a1165.jpg", alt: "Église, allée centrale",             w: 560 },
  { src: "/images/portfolio-strip/11_a37af623.jpg", alt: "Cérémonie laïque extérieure",        w: 620 },
  { src: "/images/portfolio-strip/12_4f08de47.jpg", alt: "Alliances, mains",                   w: 380 },
  { src: "/images/portfolio-strip/13_f97907ca.jpg", alt: "Mariée + bouquet",                   w: 320 },
  { src: "/images/portfolio-strip/14_b88c2457.jpg", alt: "Composition pampa, socle",           w: 320 },
  { src: "/images/portfolio-strip/15_9392a4cb.jpg", alt: "Réception, charpente bois",          w: 580 },
  { src: "/images/portfolio-strip/16_d03e2066.jpg", alt: "Salle longue, suspensions",          w: 460 },
  { src: "/images/portfolio-strip/17_f9bdf9b5.jpg", alt: "Couvert — menu & merci",             w: 360 },
];

// Témoignages clients — la flèche du carrousel cycle à travers cette liste.
// Chaque avis a sa propre photo affichée à gauche.
const testimonials = [
  {
    quote: "Merci encore pour ce mariage qui était tout simplement magique&nbsp;! Tu as fait un travail remarquable en moins de 6 mois&nbsp;! Je recommande à 100&nbsp;%&nbsp;!",
    author: "Mélodie & Thibault",
    image: "/images/testimonial.jpg",
    imageAlt: "Mariée vue d'en haut dans l'escalier",
    keyPrefix: "home.testimonial.1",
  },
  {
    quote: "Merci beaucoup pour l'organisation de notre mariage&nbsp;! Ton souci du détail, ton dévouement ont rendu notre journée parfaite voir plus que parfaite. Nous te sommes reconnaissants pour les magnifiques souvenirs que tu as contribuée à créer et te souhaitons beaucoup de succès dans l'organisation de tes prochains évènements.<br /><br /><em class=\"font-italic-serif italic text-[1.2rem] md:text-[1.9rem] leading-[1.45] md:leading-[1.4]\">Nous recommandons Aritia sans aucune hésitation.</em>",
    author: "ELITAH & FYDERANA",
    image: "/images/testimonial-2.jpg",
    imageAlt: "Mariée avec bouquet",
    long: true,
    keyPrefix: "home.testimonial.2",
  },
];
---

<Layout
  title="Aritia Design — Wedding & Event Designer | France"
  description="Basée à Toulouse, l'agence conçoit vos mariages et évènements d'exception partout en France. Direction artistique, scénographie immersive, design floral et papeterie sur-mesure."
  transparentHeader={true}
>
  {/* ───────────────────────── 1. HERO ───────────────────────── */}
  <section
    class="relative h-screen min-h-[640px] w-full overflow-hidden text-white bg-center bg-cover bg-no-repeat"
    style="background-image: url('/images/hero-poster.jpg');"
  >
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/25"></div>

    <div class="relative h-full flex flex-col items-center justify-center md:justify-end text-center px-6 md:pb-[5%]">
      <h1 class="font-display font-normal text-white text-[22px] sm:text-[30px] md:text-[40px] leading-[1.4] md:leading-[52px] tracking-[0.03em] sm:tracking-[0.05em]" data-i18n="home.hero.title">
        DIRECTION ARTISTIQUE<br />
        DESIGN FLORAL
        <span class="hidden md:inline-block mx-2 md:mx-3 align-middle text-white text-[14px] sm:text-[16px] md:text-[20px] relative top-[-3px] sm:top-[-4px] md:top-[-5px]">✦</span>
        SCÉNOGRAPHIE<br />
        CRÉATION <span class="font-italic-serif italic font-normal">de</span> PAPETERIE
      </h1>
      <p class="mt-14 md:mt-16 text-[12px] sm:text-[13px] md:text-[15px] tracking-[1.6px] sm:tracking-[2px] md:tracking-[2.25px] uppercase text-white/85" data-i18n="home.hero.subtitle">
        Créatrice d'univers pour mariages<br />
        &amp; évènements d'exception
      </p>

    </div>
  </section>

  {/* ───────────────────────── 2. INTRO ───────────────────────── */}
  <section id="intro" class="bg-white py-14 md:py-28 px-6">
    <div class="mx-auto text-center max-w-[1100px]">
      <h2 class="font-display font-normal text-[1.55rem] sm:text-[2.4rem] md:text-[2.8rem] leading-tight tracking-wide" data-i18n="home.intro.h2">
        CRÉATRICE D'UNIVERS ÉVÈNEMENTIELS<br />HAUT DE GAMME
      </h2>
      <p class="mt-7 md:mt-14 text-[0.7rem] sm:text-[0.82rem] tracking-[0.14em] sm:tracking-[0.18em] uppercase leading-[2] text-[var(--color-ink-soft)]" data-i18n="home.intro.p">
        Aritia Design vous accompagne dans la conception de mariages<br class="hidden md:inline" />
        et évènements sur-mesure, raffinés et authentiques.<br class="hidden md:inline" />
        À Toulouse, comme partout en France.
      </p>
    </div>
  </section>

  {/* ───────────────────────── 3. PORTFOLIO STRIP (marquee) ───────────────── */}
  <section class="bg-[#1a1a1a] text-white relative overflow-hidden pt-[70px] pb-[70px] md:pt-[110px] md:pb-[110px]">
    {/* solid side bands of the portfolio section — overlay on top of the marquee */}
    <div class="pointer-events-none absolute inset-y-0 left-0 w-6 md:w-[110px] bg-[#1a1a1a] z-20"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-6 md:w-[110px] bg-[#1a1a1a] z-20"></div>

    {/* big PORTFOLIO heading — anchored at top, just inside the left dark band */}
    <h2
      class="font-display font-normal text-white leading-none tracking-[0.01em]
             text-[40px] sm:text-[60px] md:text-[64px] lg:text-[88px]
             absolute z-30
             top-[41px] sm:top-[70px] md:top-[49px]
             left-1/2 -translate-x-1/2 md:left-[170px] md:translate-x-0
             select-none pointer-events-none"
      data-i18n="home.portfolio.label"
    >
      PORTFOLIO
    </h2>

    <div class="marquee relative w-full" data-marquee>
      <div class="marquee-track gap-[10px] md:gap-[20px] items-center">
        {[...portfolioImages, ...portfolioImages].map((img, i) => (
          <a
            href="/portfolio"
            class="shrink-0 block h-[200px] md:h-[480px] w-[calc(var(--w)*0.4)] md:w-[var(--w)] overflow-hidden bg-neutral-800 group"
            style={`--w: ${img.w}px;`}
            aria-label={img.alt}
            tabindex={i < portfolioImages.length ? 0 : -1}
            aria-hidden={i >= portfolioImages.length ? "true" : undefined}
          >
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </a>
        ))}
      </div>
    </div>

    <script is:inline>
      (function () {
        const marquee = document.querySelector("[data-marquee]");
        if (!marquee) return;
        const track = marquee.querySelector(".marquee-track");
        if (!track) return;

        const SPEED = 1; // px per frame (~60 px/s at 60fps)
        let paused = false;
        let resumeTimer;

        // Auto-advance scroll. Loop seamlessly: items are duplicated, so wrapping
        // back at half the track width is invisible to the eye.
        function tick() {
          if (!paused) {
            const half = track.scrollWidth / 2;
            if (half > 0) {
              marquee.scrollLeft += SPEED;
              if (marquee.scrollLeft >= half) marquee.scrollLeft -= half;
            }
          }
          requestAnimationFrame(tick);
        }
        if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
          requestAnimationFrame(tick);
        }

        const pause = () => { paused = true; clearTimeout(resumeTimer); };
        const scheduleResume = (delay) => {
          clearTimeout(resumeTimer);
          resumeTimer = setTimeout(() => { paused = false; }, delay);
        };

        // Desktop: pause on cursor enter, resume immediately on cursor leave.
        marquee.addEventListener("mouseenter", pause);
        marquee.addEventListener("mouseleave", () => {
          clearTimeout(resumeTimer);
          paused = false;
        });

        // Mouse wheel / trackpad horizontal scroll → pause briefly while user drives.
        marquee.addEventListener("wheel", () => {
          pause();
          scheduleResume(1500);
        }, { passive: true });

        // Touch: pause while finger is down, resume 2s after release.
        marquee.addEventListener("touchstart",  pause,                       { passive: true });
        marquee.addEventListener("touchend",    () => scheduleResume(2000),  { passive: true });
        marquee.addEventListener("touchcancel", () => scheduleResume(2000),  { passive: true });

        // Click an image → smooth-scroll to centre it.
        marquee.querySelectorAll("a").forEach((a) => {
          a.addEventListener("click", (e) => {
            e.preventDefault();
            pause();
            const rect = a.getBoundingClientRect();
            const mqRect = marquee.getBoundingClientRect();
            const target = marquee.scrollLeft + (rect.left - mqRect.left) - (mqRect.width - rect.width) / 2;
            marquee.scrollTo({ left: target, behavior: "smooth" });
            scheduleResume(2500);
          });
        });
      })();
    </script>

    {/* VOIR GALLERY — bottom band, right edge aligned with the gallery's right edge */}
    <div class="absolute z-30 left-0 right-0 bottom-0 h-[60px] md:h-[110px] px-6 md:px-[110px] flex items-center justify-end">
      <SparkLink
        href="/portfolio"
        label="Voir Gallery"
        i18nKey="home.portfolio.cta"
        arrowClass="h-[22px] w-[22px] md:h-[37px] md:w-[37px]"
        class="!text-[12px] md:!text-[18px] !tracking-[0.18em] md:!tracking-[0.2em] !gap-2 md:!gap-3"
      />
    </div>
  </section>

  {/* ───────────────────────── 4. MÉTHODE DE TRAVAIL ───────────────────────── */}
  <section class="bg-white px-6 pt-16 pb-[200px] md:pt-[140px] md:pb-[260px] overflow-x-hidden">
    <div class="mx-auto max-w-[1200px] grid md:grid-cols-2 gap-14 md:gap-20 items-center w-full">
      <div class="relative order-2 md:order-1">
        <div class="h-[400px] md:h-[480px] bg-cream overflow-hidden">
          <img
            src="/images/methode.jpg"
            alt="Voiture orange ornée de fleurs blanches"
            class="w-full h-full object-cover"
            onerror="this.style.background='linear-gradient(135deg,#e8d8c0,#c69d6a)';this.removeAttribute('src');"
          />
        </div>
        <p class="font-script text-[32px] md:text-[42px] lg:text-[50px] leading-[1.1] text-[var(--color-ink)] absolute right-2 md:-right-32 -bottom-[90px] md:-bottom-[135px] whitespace-nowrap text-center rotate-[-10deg]" data-i18n="home.method.script">
          Transformez chaque<br />occasion en<br />moment d'exception
        </p>
      </div>

      <div class="md:pl-6 text-center flex flex-col items-center order-1 md:order-2">
        <h2 class="font-display font-light text-[40px] sm:text-[44px] md:text-[48px] lg:text-[60px] leading-[1.1]" data-i18n="home.method.h2">
          MÉTHODE<br />
          <span class="font-italic-serif italic">de</span> TRAVAIL
        </h2>
        <p class="mt-8 text-[16px] leading-[1.9] text-[var(--color-ink-soft)] max-w-md" data-i18n="home.method.p">
          De la première inspiration au jour J, je vous accompagne avec
          sensibilité et exigence dans la création d'un univers qui vous
          ressemble&nbsp;– une approche sur-mesure, pensée pour faire
          naître la beauté et l'émotion.
        </p>
        <a
          href="/processus"
          class="inline-block mt-10 px-10 py-4 border border-[var(--color-ink)] text-[0.72rem] tracking-[0.32em] uppercase hover:bg-[var(--color-ink)] hover:text-white transition"
          data-i18n="home.method.cta"
        >
          Découvrir
        </a>
      </div>
    </div>
  </section>

  {/* ───────────────────────── 5. MARIAGE / OCCASION SPÉCIALE ───────────────────────── */}
  <section class="bg-[#1a1a1a] text-white py-28 md:py-36 px-6">
    <div class="mx-auto max-w-[1200px] grid md:grid-cols-2 gap-14 md:gap-20 items-center">
      <div class="md:order-1 order-2 text-center flex flex-col items-center">
        <h2 class="font-display font-light text-[36px] sm:text-[44px] md:text-[48px] lg:text-[60px] leading-[1.1]" data-i18n="home.mariage.h2">
          MARIAGE<br />
          <span class="font-italic-serif italic">Occasion Spéciale</span>
        </h2>
        <p class="mt-8 text-[16px] leading-[1.9] text-white/80 max-w-md" data-i18n="home.mariage.p">
          À travers une approche transversale mêlant design floral,
          scénographie immersive, papeterie personnalisée et identité
          visuelle, je conçois à vos côtés un univers esthétique global,
          où chaque choix incarne avec exigence l'essence de votre histoire.
        </p>
        <a
          href="/services"
          class="inline-block mt-10 px-10 py-4 border border-white text-[0.72rem] tracking-[0.32em] uppercase hover:bg-white hover:text-[var(--color-ink)] transition"
          data-i18n="home.mariage.cta"
        >
          Explorer
        </a>
      </div>

      <div class="md:order-2 order-1 aspect-[4/3] overflow-hidden">
        <img
          src="/images/mariage.jpg"
          alt="Salle de réception de mariage avec tables dressées"
          class="w-full h-full object-cover"
          onerror="this.style.background='linear-gradient(135deg,#3a3530,#1a1a1a)';this.removeAttribute('src');"
        />
      </div>
    </div>
  </section>

  {/* ───────────────────────── 6. MOSAÏQUE PHOTOS (desktop only) ───────────────────────── */}
  <section class="hidden md:block bg-white py-28 md:py-36 px-6">
    <div class="mx-auto max-w-[1100px] relative h-[600px] md:h-[720px]">
      {/* Gauche — petit format, positionné pour recouvrir le visage de l'homme dans la photo centrale */}
      <div class="absolute left-[5.5%] top-[4%] w-[28%] aspect-square overflow-hidden shadow-sm z-10">
        <img
          src="/images/collage-salon.jpg"
          alt="Salon classique avec lustre"
          class="w-full h-full object-cover"
          onerror="this.style.background='linear-gradient(135deg,#d8c9b3,#a8896a)';this.removeAttribute('src');"
        />
      </div>
      {/* Centre — grande photo dominante (portrait) */}
      <div class="absolute left-[26%] top-0 w-[40%] aspect-[3/4] overflow-hidden shadow-sm z-0">
        <img
          src="/images/collage-personne.jpg"
          alt="Invitée au chapeau blanc"
          class="w-full h-full object-cover"
          onerror="this.style.background='linear-gradient(135deg,#1f2a3a,#0e1828)';this.removeAttribute('src');"
        />
      </div>
      {/* Droite — format paysage, juste sous l'épaule de la femme, décalé à droite pour laisser voir le bouquet */}
      <div class="absolute right-[1%] top-[47%] w-[38%] aspect-[4/3] overflow-hidden shadow-sm z-10">
        <img
          src="/images/collage-lieu.jpg"
          alt="Domaine de réception avec fontaine"
          class="w-full h-full object-cover"
          onerror="this.style.background='linear-gradient(135deg,#6a8d59,#3a5a40)';this.removeAttribute('src');"
        />
      </div>
    </div>
  </section>

  {/* ───────────────────────── 7. TÉMOIGNAGE ───────────────────────── */}
  <section class="bg-white pt-16 md:pt-0 pb-[100px] md:pb-36 px-6">
    <div class="mx-auto max-w-[1100px] grid md:grid-cols-2 gap-12 md:gap-16 items-center">
      <div class="aspect-[3/4] overflow-hidden relative" data-testimonial-images>
        {testimonials.map((t, i) => (
          <img
            src={t.image}
            alt={t.imageAlt}
            data-i18n-attr={`alt:${t.keyPrefix}.imgalt`}
            class="testimonial-image absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ease-in-out"
            data-index={i}
            style={i === 0 ? "opacity:1;" : "opacity:0;"}
            onerror="this.style.background='linear-gradient(135deg,#cfc1ad,#7a6a5a)';this.removeAttribute('src');"
          />
        ))}
      </div>
      <figure class="md:pl-8 relative" data-testimonial-carousel>
        <div class="relative">
          {testimonials.map((t, i) => (
            <div
              class:list={[
                "testimonial-slide transition-opacity duration-500 ease-in-out flex flex-col justify-start md:justify-center",
                i !== 0 ? "absolute inset-x-0 top-0" : "",
              ]}
              data-index={i}
              style={i === 0 ? "opacity:1;" : "opacity:0;pointer-events:none;"}
            >
              <div class="relative">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 300.57 256.05"
                  fill="currentColor"
                  aria-hidden="true"
                  class="w-[26px] md:w-[35px] h-auto text-black/15 absolute left-[-11px] md:left-[-15px] top-[-2px] md:top-[-4px] select-none pointer-events-none"
                >
                  <path d="M79.7,0c3.15-.08,6.88,3.46,5.48,6.73-19.01,19.82-33.89,42.68-41.53,69.31-6.22,21.7-9.88,56.31-.73,77.33.47,1.08,3.51,7.14,4.33,7.14,6.46-9.29,16.51-12.98,27.47-13.96,40.92-3.67,64.7,26.02,58.02,65.5-5.34,31.55-34.91,45.27-64.54,43.85C-4.46,252.43-8.43,155.59,7.93,103.23,18.54,69.26,42.49,36.38,66.97,10.98c2.48-2.58,7.12-7.85,9.74-9.73.83-.6,1.96-1.23,2.99-1.26Z" />
                  <path d="M213.29,160.52c.33.28.7.03,1.03-.32,1.52-1.59,2.42-3.66,4.45-5.43,9.83-8.59,29.21-9.67,41.56-7.6,53.27,8.95,55.54,95.33-4.51,107.06-49.93,9.75-79.52-20.91-86.9-67.59-10.86-68.65,15.37-123.22,61.08-171.92,3.29-3.51,10.2-11.21,13.72-13.74,3.78-2.72,8.95.94,8.31,5.28-16.54,17.67-30.51,37.15-38.75,60.14-8.46,23.58-14.07,64.24-3.57,87.47.39.86,3.29,6.4,3.59,6.65Z" />
                </svg>
                <blockquote
                  class:list={[
                    "text-[var(--color-ink)] relative",
                    t.long
                      ? "font-display text-[1rem] md:text-[1.45rem] leading-[1.6] md:leading-[1.5]"
                      : "font-gilda italic text-[1.2rem] md:text-[1.9rem] leading-[1.45] md:leading-[1.4]",
                  ]}
                  data-i18n={`${t.keyPrefix}.quote`}
                  set:html={t.quote}
                />
              </div>
              <div class="mt-6 md:mt-8 flex items-center gap-4 md:gap-5">
                <figcaption class="text-[0.62rem] md:text-[0.72rem] tracking-[0.26em] md:tracking-[0.32em] uppercase text-[var(--color-muted)]">
                  — <span data-i18n={`${t.keyPrefix}.author`}>{t.author}</span>
                </figcaption>
                <button
                  type="button"
                  data-testimonial-next
                  aria-label="Témoignage suivant"
                  data-i18n-attr="aria-label:home.testimonial.next"
                  class="flex items-center justify-center text-black/15 hover:text-[var(--color-burgundy)] transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 442 793" fill="currentColor" class="h-4 md:h-5 w-auto rotate-90">
                    <path d="M442,240c-48.43-2.43-97.83-17.78-138.52-43.98-16.1-10.37-31.48-28.88-52.4-16.44-5,2.97-13.08,13.31-13.08,18.92v594.5h-34c-.27-.73,1-1.2,1-1.5V204.5c0-11.84-9.42-24.9-20.96-28.04-18.54-5.05-31.93,10.88-46.13,19.96C97.23,222.43,48.38,237.78,0,240v-32.5c.63-.99,1.38-1.29,2.5-1.5,4.69-.86,12.31-.38,17.86-1.14,50.4-6.91,110.18-33.41,142.61-73.39C193.06,94.4,203.87,47.09,205,0h31.5c3.05,5.87,1.01,14.58,1.51,21.49,7.59,105.17,82.63,169.13,183.62,183.38,5.44.77,13.07.26,17.87,1.13,1.12.2,1.87.51,2.5,1.5v32.5Z" />
                  </svg>
                </button>
              </div>
            </div>
          ))}
        </div>
      </figure>
    </div>
  </section>

  {/* ───────────────────────── 8. À PROPOS (fond marbre noir) ───────────────────────── */}
  <section class="relative text-white overflow-hidden">
    {/* black marble background */}
    <div
      class="absolute inset-0 bg-[#0e0e0e]"
      style="background-image: url('/images/marble.jpg'); background-size: cover; background-position: center;"
    ></div>
    <div class="absolute inset-0 bg-black/40"></div>

    <div class="relative mx-auto max-w-[1300px] px-6 lg:px-14 pt-16 md:pt-24 pb-28 md:pb-36 grid md:grid-cols-2 gap-14 md:gap-20 items-center">
      {/* photo + script overlay */}
      <div class="relative">
        <div class="aspect-[5/4] overflow-hidden bg-neutral-800 shadow-xl">
          <img
            src="/images/aritia-portrait.jpg"
            alt="Aritia, fondatrice d'Aritia Design"
            data-i18n-attr="alt:home.aritia.portrait.alt"
            class="w-full h-full object-cover"
          />
        </div>
