---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SparkLink from "../components/SparkLink.astro";

const steps = [
  {
    n: "01",
    title: "PREMIÈRE RENCONTRE",
    body: "Tout commence par une rencontre. Nous prenons le temps de faire connaissance, d'écouter votre histoire et de comprendre ce qui rend votre projet unique. Ensemble, nous parlons des fleurs que vous aimez, des couleurs qui vous ressemblent, du mobilier que vous imaginez, du lieu que vous avez choisi. Ces informations nous permettront de vous fournir un devis personnalisé, remis sous 7 à 10 jours ouvrés selon l'ampleur de votre projet.",
    image: "/images/step-01-roses.jpg",
    alt: "Roses blanches",
    contained: true,
    gridGap: "gap-14",
  },
  {
    n: "02",
    title: "DEVIS & SIGNATURE",
    body: "Votre signature ouvre officiellement notre collaboration. Au-delà du cadre formel, elle scelle un engagement mutuel au sein duquel vous nous confiez votre vision et nous nous engageons à la traduire avec exigence et passion.",
    stack: [
      "/images/contract/page-02.jpg",
      "/images/contract/page-01.jpg",
    ],
    alt: "Contrat & Mandat — Aritia Design",
    gridGap: "max-md:gap-16 gap-0",
    marginTop: "max-md:mt-0 mt-28 md:mt-40",
  },
  {
    n: "03",
    title: "INSPIRATIONS & UNIVERS",
    body: "Pour chaque temps fort de la célébration (cérémonie, cocktail, dîner), selon vos envies, nous composons des planches d'intentions autour des ambiances, matières, palette, fleurs et typographies. Un fil rouge visuel et émotionnel se dessine. Au gré d'échanges réguliers avec vous ou votre wedding planner, il se précise, s'ajuste, s'enrichit, jusqu'à devenir le reflet le plus juste de votre histoire.",
    image: "/images/step-03-moodboard.jpg",
    alt: "Moodboard — direction artistique",
    contained: true,
    gridGap: "gap-14",
    marginTop: "max-md:mt-0 mt-28 md:mt-40",
  },
  {
    n: "04",
    title: "PRÉSENTATION DU PROJET",
    body: "Nous traduisons cette vision en un projet complet, harmonisant compositions florales, papeterie, signalétique et agencement des espaces. C'est le moment de la révélation. Votre carnet d'atmosphère détaillé rassemble photos des pièces sélectionnées, croquis de projection et planches d'inspiration. Votre univers prend enfin forme sous vos yeux. Une fois le carnet entre vos mains, vous pouvez encore valider, échanger ou affiner certains détails selon vos envies.",
    flipbook: Array.from({ length: 23 }, (_, i) =>
      `/images/flipbook/${String(i + 1).padStart(2, "0")}.jpg`
    ),
    alt: "Présentation — Carnet d'atmosphère",
    gridGap: "max-md:gap-20 md:gap-14",
    // Per-page watermark opacity (index 0 = cover, already branded → hide).
    watermarkOpacities: { 0: 0 } as Record<number, number>,
  },
  {
    n: "05",
    title: "DANS LES COULISSES",
    body: "Le dossier validé, nous passons commande auprès de nos partenaires et coordonnons l'ensemble. Sourcing, production sur mesure, ajustements, échanges réguliers avec vous ou votre wedding planner, tout est pris en main. Vous restez maître de la vision ; nous orchestrons en coulisses.",
    stack: [
      "/images/tableaux/elements.jpg",
      "/images/tableaux/calcul-fleurs.jpg",
    ],
    alt: "Tableaux d'orchestration",
    landscape: true,
    gridGap: "max-md:gap-12 gap-0",
    marginTop: "max-md:mt-0 mt-28 md:mt-40",
  },
  {
    n: "06",
    title: "LE JOUR J",
    body: "Le jour J, nous nous occupons de tout. Installation, mise en place, compositions florales in situ, ajustements de dernière minute. Vivez votre journée en toute sérénité ; votre vision se déploie telle que vous l'aviez rêvée.",
    image: "/images/step-06-colonnes.jpg",
    alt: "Colonnes plan de table avec roses blanches",
    contained: true,
    script: "Place à l'émotion.",
    gridGap: "gap-14",
    marginTop: "max-md:mt-0 mt-28 md:mt-40",
  },
];
---

<Layout title="PROCESSUS | Aritia Design" transparentHeader={true}>
  <PageHero
    image="/images/processus-hero-bg.jpg"
    imageAlt="Processus créatif"
    titleHtml="Processus"
    titleKey="process.pagehero.title"
    subtitleHtml={`Une méthode pensée, façonnée<br class="show-mobile" />autour de votre vision.`}
    subtitleKey="process.pagehero.subtitle"
  />

  {/* ───────────────────────── INTRO TEXT ───────────────────────── */}
  <section class="bg-[#1a1a1a] text-white pt-20 md:pt-32 pb-6 md:pb-10 px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-display font-light text-[1.25rem] sm:text-[2rem] md:text-[2.7rem] leading-[1.2] !tracking-[0.1em]" data-i18n="process.intro.h2">
        UN ACCOMPAGNEMENT<br />
        <span>EN 6 ÉTAPES</span>
      </h2>
      <p class="mt-6 md:mt-10 text-[0.62rem] sm:text-[0.78rem] tracking-[0.18em] sm:tracking-[0.22em] uppercase leading-[1.95] text-white/85" data-i18n="process.intro.p">
        De la première rencontre au jour J,<br />
        vivez la création de votre univers<br />
        en toute sérénité.
      </p>
    </div>
  </section>

  {/* ───────────────────────── HERO QUOTE ───────────────────────── */}
  <section class="bg-[#1a1a1a] text-white pt-6 md:pt-10 pb-10 md:pb-40 px-6">
    <div class="mx-auto max-w-[1100px] text-center">
      <h1 class="inline-block font-script font-normal text-[1.4rem] sm:text-[1.9rem] md:text-[2.8rem] lg:text-[3.2rem] leading-[1.4] text-white" data-i18n="process.hero.quote">
        «&nbsp;La création, c’est<br class="md:hidden" /> l’équilibre entre<br class="hidden md:inline" /> maîtrise<br class="md:hidden" /> et lâcher-prise.&nbsp;»
      </h1>
    </div>
  </section>

  {/* ───────────────────────── SEPARATOR — citation → étape 01 (mobile/tablet only) ───────────────────────── */}
  <div class="lg:hidden bg-[#1a1a1a] px-6 py-10" aria-hidden="true">
    <div class="mx-auto max-w-[200px] flex items-center justify-center gap-4 md:gap-5">
      <span class="flex-1 h-px bg-white/20"></span>
      <span class="flex items-center gap-2 md:gap-2.5 text-[9px] md:text-[10px] text-white/70 tracking-normal">
        <span>✦</span><span>✦</span><span>✦</span>
      </span>
      <span class="flex-1 h-px bg-white/20"></span>
    </div>
  </div>

  {/* ───────────────────────── 4. SIX STEPS ───────────────────────── */}
  <section class="bg-[#1a1a1a] text-white pt-10 md:pt-32 pb-24 md:pb-36 px-6">
    <div class="mx-auto max-w-[1200px]">
      {steps.map((step, i) => {
        const reversed = i % 2 === 1;
        const defaultMt = i === 0 ? "" : "max-md:mt-0 mt-28 md:mt-40";
        const mt = i === 0 ? "" : (step.marginTop ?? defaultMt);
        return (
          <div class:list={["relative", mt]}>
            <div class:list={[
              "grid lg:grid-cols-2 lg:gap-20 items-center",
              step.gridGap ?? "gap-14",
            ]}>
              {/* Image — static or flipbook */}
              {step.flipbook ? (
                <div
                  class:list={[
                    "flipbook relative aspect-[2000/1414] w-full overflow-hidden bg-[var(--color-cream)] shadow-[0_24px_60px_-24px_rgba(0,0,0,0.25)] select-none group",
                    "order-2",
                    reversed ? "lg:order-2" : "lg:order-1",
                  ]}
                  data-flipbook
                  tabindex="0"
                  aria-label={`Flipbook ${step.alt} — utilisez les flèches gauche / droite pour naviguer`}
                >
                  {/* Pages stack */}
                  {step.flipbook.map((src, idx) => {
                    const watermarkOpacity = step.watermarkOpacities?.[idx] ?? 0.06;
                    return (
                      <div
                        data-page={idx}
                        class="absolute inset-0 transition-opacity duration-500 ease-out"
                        style={`opacity: ${idx === 0 ? 1 : 0}; z-index: ${idx === 0 ? 2 : 1}; pointer-events: ${idx === 0 ? "auto" : "none"};`}
                      >
                        <img
                          src={src}
                          alt={`${step.alt} — page ${idx + 1}`}
                          loading={idx < 2 ? "eager" : "lazy"}
                          class="absolute inset-0 w-full h-full object-cover"
                        />
                        {watermarkOpacity > 0 && (
                          <img
                            src="/images/watermark-ad.svg"
                            alt=""
                            aria-hidden="true"
                            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-1/2 max-w-[320px] pointer-events-none select-none"
                            style={`opacity: ${watermarkOpacity}; filter: invert(1);`}
                          />
                        )}
                      </div>
                    );
                  })}

                  {/* Prev / Next click zones */}
                  <button
                    type="button"
                    data-prev
                    class="absolute inset-y-0 left-0 w-1/2 z-[4] cursor-w-resize flex items-center justify-start pl-3 md:pl-6"
                    aria-label="Page précédente"
                    data-i18n-attr="aria-label:process.flipbook.prev"
                  >
                    <span class="inline-flex items-center justify-center w-9 h-9 md:w-11 md:h-11 rounded-full bg-[#1a1a1a]/85 backdrop-blur-sm text-white shadow hover:bg-[#1a1a1a] transition">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 6l-6 6 6 6"/></svg>
                    </span>
                  </button>
                  <button
                    type="button"
                    data-next
                    class="absolute inset-y-0 right-0 w-1/2 z-[4] cursor-e-resize flex items-center justify-end pr-3 md:pr-6"
                    aria-label="Page suivante"
                    data-i18n-attr="aria-label:process.flipbook.next"
                  >
                    <span class="inline-flex items-center justify-center w-9 h-9 md:w-11 md:h-11 rounded-full bg-[#1a1a1a]/85 backdrop-blur-sm text-white shadow hover:bg-[#1a1a1a] transition">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 6l6 6-6 6"/></svg>
                    </span>
                  </button>

                </div>
              ) : step.stack ? (
                <div
                  class:list={[
                    "md:aspect-[1/1] flex items-center justify-center bg-[#1a1a1a] px-6 md:px-10 py-0 md:py-14",
                    "order-2",
                    reversed ? "lg:order-2" : "lg:order-1",
                  ]}
                >
                  <div class:list={[
                    "relative",
                    step.landscape ? "w-[95%] md:w-[88%] aspect-[1.414/1]" : "w-[62%] aspect-[1/1.414]",
                  ]}>
                    {/* Fan-shaped stack — rotations pivot around bottom-center
                        so the back pages swing up-right while the front leans left,
                        like the A4 mockup reference. */}
                    {(() => {
                      // Layouts per stack size — back-to-front order.
                      const layoutsByCount = {
                        2: [
                          { tx:  9, ty: -3, rot:  4, isFront: false }, // back  — page-02
                          { tx: -2, ty:  1, rot: -4, isFront: true  }, // front — page-01
                        ],
                        4: [
                          { tx:  5, ty: -2, rot:  14, isFront: false },
                          { tx:  3, ty: -1, rot:   8, isFront: false },
                          { tx:  1, ty:  0, rot:   2, isFront: false },
                          { tx: -2, ty:  1, rot:  -6, isFront: true  },
                        ],
                      };
                      const layouts = layoutsByCount[step.stack.length] || layoutsByCount[4];
                      const offset = Math.max(0, layouts.length - step.stack.length);
                      return step.stack.map((src, idx) => {
                        const layout = layouts[offset + idx] || layouts[layouts.length - 1];
                        // Softer single drop-shadow matching the flipbook intensity.
                        const shadow = "drop-shadow(0 16px 24px rgba(0,0,0,0.10))";
                        return (
                          <img
                            src={src}
                            alt={`${step.alt} — page ${idx + 1}`}
                            loading="lazy"
                            class="absolute inset-0 w-full h-full object-cover bg-[#1a1a1a]"
                            style={`transform-origin: 50% 95%; transform: translate(${layout.tx}%, ${layout.ty}%) rotate(${layout.rot}deg); filter: ${shadow}; z-index: ${idx + 1};`}
                          />
                        );
                      });
                    })()}
                  </div>
                </div>
              ) : step.contained ? (
                <div
                  class:list={[
                    "relative aspect-[5/7] md:aspect-[1/1] flex items-center justify-center bg-[#1a1a1a] px-2 md:px-10 py-3 md:py-10",
                    "order-2",
                    reversed ? "lg:order-2" : "lg:order-1",
                  ]}
                >
                  <img
                    src={step.image}
                    alt={step.alt}
                    loading="lazy"
                    class="max-w-full max-h-full object-contain"
                  />
                  {step.watermarkBottomLeft && (
                    <img
                      src="/images/watermark-ad-dark.svg"
                      alt=""
                      aria-hidden="true"
                      class="hidden md:block absolute md:-left-[400px] md:-bottom-32 md:w-[400px] pointer-events-none select-none"
                      style="opacity: 0.1;"
                    />
                  )}
                </div>
              ) : (
                <div
                  class:list={[
                    "aspect-[1/1] overflow-hidden bg-[var(--color-cream)]",
                    "order-2",
                    reversed ? "lg:order-2" : "lg:order-1",
                  ]}
                >
                  <img
                    src={step.image}
                    alt={step.alt}
                    loading="lazy"
                    class="w-full h-full object-cover"
                    onerror="this.style.background='linear-gradient(135deg,#e8d8c0,#c69d6a)';this.removeAttribute('src');"
                  />
                </div>
              )}

              {/* Text */}
              <div class:list={[
                "order-1 relative",
                reversed ? "lg:order-1 lg:pr-8" : "lg:order-2 lg:pl-8",
                step.textOffset ?? "",
              ]}>
                <h3 class="processus-step-title font-display font-light text-[clamp(1.2rem,2.6vw,1.35rem)] leading-[1.25] text-white text-balance flex flex-wrap items-baseline gap-x-1.5 sm:gap-x-2 !tracking-[0.1em]">
                  <span class="font-gilda tracking-normal">{step.n}</span>
                  <span class="font-gilda tracking-normal" aria-hidden="true">/</span>
                  <span data-i18n={`process.step.${i + 1}.title`}>
                    {step.title.split("&").map((part, idx, arr) => (
                      <>
                        {part}
                        {idx < arr.length - 1 && <span class="amp">&amp;</span>}
                      </>
                    ))}
                  </span>
                </h3>
                <svg
                  class="mt-8 hidden lg:block text-white"
                  width="105"
                  height="12"
                  viewBox="0 0 90 10"
                  fill="currentColor"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  {/* horizontal line passing through the first sparkle */}
                  <line x1="0" y1="5" x2="55" y2="5" stroke-width="0.35" />
                  {/* 4-point sparkle through the line */}
                  <path d="M48 2.5 Q48.3 4.7 50.5 5 Q48.3 5.3 48 7.5 Q47.7 5.3 45.5 5 Q47.7 4.7 48 2.5 Z" stroke="none" />
                  {/* second sparkle */}
                  <path d="M65 2.5 Q65.3 4.7 67.5 5 Q65.3 5.3 65 7.5 Q64.7 5.3 62.5 5 Q64.7 4.7 65 2.5 Z" stroke="none" />
                  {/* third sparkle */}
                  <path d="M82 2.5 Q82.3 4.7 84.5 5 Q82.3 5.3 82 7.5 Q81.7 5.3 79.5 5 Q81.7 4.7 82 2.5 Z" stroke="none" />
                </svg>
                <p class="mt-6 lg:mt-6 text-[0.95rem] leading-[1.95] text-white/85 max-w-md" data-i18n={`process.step.${i + 1}.body`}>
                  {step.body}
                </p>
                {step.script && (
                  <p
                    class="hidden lg:block absolute right-0 top-full mt-6 md:mt-10 translate-x-6 md:translate-x-12 w-fit font-script text-[28px] sm:text-[34px] md:text-[40px] lg:text-[48px] leading-[1.1] text-white text-center rotate-[-10deg] origin-left pointer-events-none select-none whitespace-nowrap"
                    data-i18n={`process.step.${i + 1}.script`}
                    set:html={`<span class="block">faites place</span>à votre instant<br />d'émotion.`}
                  />
                )}
              </div>
            </div>

            {step.script && (
              <p
                class="lg:hidden relative z-10 -mt-6 sm:-mt-8 mx-auto w-fit font-script text-[32px] sm:text-[42px] leading-[1.1] text-white text-center rotate-[-10deg] origin-center pointer-events-none select-none whitespace-nowrap"
                data-i18n={`process.step.${i + 1}.script`}
                set:html={`<span class="block">faites place</span>à votre instant<br />d'émotion.`}
              />
            )}

            {/* Mobile/tablet only: ✦✦✦ divider between this step and the next */}
            {i < steps.length - 1 && (
              <div class="lg:hidden my-20 mx-auto w-fit flex items-center justify-center gap-4 md:gap-5" aria-hidden="true">
                <span class="w-4 h-px bg-white/20"></span>
                <span class="flex items-center gap-2 md:gap-2.5 text-[9px] md:text-[10px] text-white/70 tracking-normal">
                  <span>✦</span><span>✦</span><span>✦</span>
                </span>
                <span class="w-4 h-px bg-white/20"></span>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </section>

  {/* ───────────────────────── 5. CLOSING MANIFESTO + CTA ───────────────────────── */}
  <section class="bg-[#1A1A1A] text-white pt-8 pb-20 md:py-28 px-6">
    <div class="mx-auto max-w-[1320px]">
      <div class="grid grid-cols-12 gap-6 md:gap-10 items-center">
        {/* Left composite: tall portrait + small square offset bottom-right */}
        <div class="col-span-12 md:col-span-4 relative pb-8 md:pb-10">
          <div class="aspect-[3/4] overflow-hidden bg-[#1a1a1a] w-[64%]">
            <img
              src="/images/closing-main.jpg"
              alt="Détail composition"
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="aspect-[4/5] overflow-hidden bg-[#1a1a1a] absolute right-[2%] bottom-0 w-[50%]">
            <img
              src="/images/closing-small.jpg"
              alt="Plan de table"
              loading="lazy"
              class="w-full h-full object-cover object-top"
            />
          </div>
        </div>

        {/* Right: italic manifesto + CTA */}
        <div class="col-span-12 md:col-span-8 md:pl-6 mt-1 md:mt-0">
          <div class="w-fit max-w-full">
            <p class="font-italic-serif italic text-[1.4rem] sm:text-[1.7rem] md:text-[40px] leading-[1.4] md:leading-[1.3] text-white text-pretty" data-i18n="process.closing">
              Notre processus créatif allie écoute,<br class="hidden md:inline" />
              intuition et exigence esthétique, pour<br class="hidden md:inline" />
              concevoir une expérience sur mesure et<br class="hidden md:inline" />
              propre à votre histoire.
            </p>

            <div class="mt-10 md:mt-14 flex justify-end">
              <SparkLink
                href="/contact"
                label="Contactez-nous"
                i18nKey="process.closing.cta"
                arrowClass="h-[22px] w-[22px] md:h-[37px] md:w-[37px]"
                class="text-white !text-[0.8rem] md:!text-[18px] !tracking-[0.16em] md:!tracking-[0.2em] !gap-2 md:!gap-3"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  @media (max-width: 767px) {
    /* Match the ampersand height to the rest of the processus step title on mobile */
    h3 .amp {
      font-size: 1em;
      vertical-align: baseline;
    }
  }
</style>

<script>
  // Flipbook navigation — crossfade between pages, keyboard + click support.
  document.querySelectorAll<HTMLElement>("[data-flipbook]").forEach((root) => {
    const pages = Array.from(root.querySelectorAll<HTMLImageElement>("[data-page]"));
    const counter = root.querySelector<HTMLElement>("[data-counter]");
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-next]");
    let current = 0;

    function show(i: number) {
      const n = pages.length;
      const next = ((i % n) + n) % n;
      pages.forEach((p, idx) => {
        const active = idx === next;
        p.style.opacity = active ? "1" : "0";
        p.style.zIndex = active ? "2" : "1";
        p.style.pointerEvents = active ? "auto" : "none";
      });
      current = next;
      if (counter) counter.textContent = String(next + 1).padStart(2, "0");
    }

    prevBtn?.addEventListener("click", () => show(current - 1));
    nextBtn?.addEventListener("click", () => show(current + 1));

    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") { e.preventDefault(); show(current - 1); }
      if (e.key === "ArrowRight") { e.preventDefault(); show(current + 1); }
    });
  });
</script>
