---
import Layout from "../layouts/Layout.astro";
import SparkLink from "../components/SparkLink.astro";

const steps = [
  {
    n: "01",
    title: "PREMIER ÉCHANGE",
    body: "Tout commence par un échange. J'apprends à vous connaître, à comprendre votre histoire, vos envies, vos inspirations. Nous définissons ensemble les contours de votre univers, les priorités, les émotions à transmettre. À l'issue de cet échange, un devis personnalisé vous est remis pour validation.",
    image: "/images/panneau-bienvenue.png",
    alt: "Panneau de bienvenue",
    gridGap: "gap-14",
  },
  {
    n: "02",
    title: "SIGNATURE DU DEVIS & CONTRAT",
    body: "La collaboration débute officiellement avec la signature du contrat, qui formalise les engagements mutuels et le cadre de notre travail.",
    stack: [
      "/images/contract/page-02.jpg",
      "/images/contract/page-01.jpg",
    ],
    alt: "Contrat & Mandat — Aritia Design",
    gridGap: "max-md:gap-2 gap-0",
    textOffset: "max-md:-mt-6",
    marginTop: "max-md:mt-0 mt-28 md:mt-40",
  },
  {
    n: "03",
    title: "INTENTIONS & DIRECTION ARTISTIQUE",
    body: "Création d'un moodboard et d'une ligne esthétique : ambiance, matières, couleurs, fleurs, typographies, style graphique… Un fil rouge visuel et émotionnel se dessine.",
    image: "/images/step-03-moodboard.jpg",
    alt: "Moodboard — direction artistique",
    gridGap: "gap-14",
    marginTop: "max-md:mt-0 mt-28 md:mt-40",
  },
  {
    n: "04",
    title: "CONCEPTION",
    body: "Je traduis cette vision en un projet complet, harmonisant les éléments visuels et scénographiques : compositions florales, papeterie, signalétique, agencement des espaces. Chaque élément trouve sa place avec justesse et cohérence.",
    flipbook: Array.from({ length: 24 }, (_, i) =>
      `/images/flipbook/${String(i + 1).padStart(2, "0")}.jpg`
    ),
    alt: "Présentation — Carnet d'atmosphère",
    gridGap: "max-md:gap-20 md:gap-14",
  },
  {
    n: "05",
    title: "ORCHESTRATION & FINALISATION",
    body: "Je pilote la réalisation de chaque élément : sourcing, production, ajustements, échanges avec vous ou votre wedding planner. Vous êtes accompagnés en toute sérénité.",
    stack: [
      "/images/tableaux/elements.jpg",
      "/images/tableaux/calcul-fleurs.jpg",
    ],
    alt: "Tableaux d'orchestration",
    landscape: true,
    gridGap: "gap-0",
    textOffset: "max-md:-mt-10",
    marginTop: "max-md:mt-0 mt-28 md:mt-40",
  },
  {
    n: "06",
    title: "INSTALLATION & MISE EN SCÈNE",
    body: "Le jour J, l'univers prend vie. Je mets en place chaque élément du décor, compose les fleurs in situ, ajuste les volumes et sublime les espaces pour offrir une expérience à la hauteur de votre histoire. Un décor vivant, élégant, fluide — à votre image.",
    image: "/images/tonga-soa.png",
    alt: "Bannière Tonga Soa",
    gridGap: "gap-14",
    marginTop: "max-md:mt-0 mt-28 md:mt-40",
  },
];
---

<Layout title="PROCESSUS | Aritia Design" transparentHeader={false}>
  {/* ───────────────────────── 1. HERO QUOTE ───────────────────────── */}
  <section class="bg-white pt-32 md:pt-40 pb-6 md:pb-10 px-6">
    <div class="mx-auto max-w-[1100px] text-center">
      <span class="flex w-fit mx-auto items-center gap-2 md:gap-4 mb-0 md:mb-24 px-3 md:px-5 py-2 md:py-3 bg-[#1a1a1a] text-white text-[0.58rem] md:text-[0.75rem] tracking-[0.22em] md:tracking-[0.32em] uppercase">
        <span aria-hidden="true">✦</span>
        <span data-i18n="process.kicker">Processus créatif</span>
        <span aria-hidden="true">✦</span>
      </span>

      <h1 class="hidden md:inline-block font-script font-normal text-[1.4rem] sm:text-[1.9rem] md:text-[2.8rem] lg:text-[3.2rem] leading-[1.4] text-[var(--color-ink)]" data-i18n="process.hero.quote">
        «&nbsp;La création, c'est l'équilibre entre<br />
        maîtrise et lâcher-prise.&nbsp;»
      </h1>
    </div>
  </section>

  {/* ───────────────────────── 3. INTRO TEXT ───────────────────────── */}
  <section class="bg-white pt-6 md:pt-10 pb-16 md:pb-20 px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-display font-light text-[1.25rem] sm:text-[2rem] md:text-[2.7rem] leading-[1.2] !tracking-[0.1em]" data-i18n="process.intro.h2">
        UN ACCOMPAGNEMENT<br />
        <span>EN 6 ÉTAPES</span>
      </h2>
      <p class="mt-6 md:mt-10 text-[0.62rem] sm:text-[0.78rem] tracking-[0.18em] sm:tracking-[0.22em] uppercase leading-[1.95] text-[var(--color-ink-soft)]" data-i18n="process.intro.p">
        De la première rencontre au jour J,<br />
        vivez la création de votre univers<br />
        en toute sérénité.
      </p>
    </div>
  </section>

  {/* ───────────────────────── 4. SIX STEPS ───────────────────────── */}
  <section class="bg-white pb-24 md:pb-36 px-6">
    <div class="mx-auto max-w-[1200px]">
      {steps.map((step, i) => {
        const reversed = i % 2 === 1;
        const defaultMt = i === 0 ? "" : "max-md:mt-0 mt-28 md:mt-40";
        const mt = i === 0 ? "" : (step.marginTop ?? defaultMt);
        return (
          <div class:list={["relative", mt]}>
            <div class:list={[
              "grid lg:grid-cols-2 lg:gap-20 items-center",
              step.gridGap ?? "gap-14",
            ]}>
              {/* Image — static or flipbook */}
              {step.flipbook ? (
                <div
                  class:list={[
                    "flipbook relative aspect-[3/2] w-full overflow-hidden bg-[var(--color-cream)] shadow-[0_24px_60px_-24px_rgba(0,0,0,0.25)] select-none group",
                    "order-2",
                    reversed ? "lg:order-2" : "lg:order-1",
                  ]}
                  data-flipbook
                  tabindex="0"
                  aria-label={`Flipbook ${step.alt} — utilisez les flèches gauche / droite pour naviguer`}
                >
                  {/* Pages stack */}
                  {step.flipbook.map((src, idx) => (
                    <img
                      src={src}
                      alt={`${step.alt} — page ${idx + 1}`}
                      loading={idx < 2 ? "eager" : "lazy"}
                      data-page={idx}
                      class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 ease-out"
                      style={`opacity: ${idx === 0 ? 1 : 0}; z-index: ${idx === 0 ? 2 : 1}; pointer-events: ${idx === 0 ? "auto" : "none"};`}
                    />
                  ))}

                  {/* Prev / Next click zones */}
                  <button
                    type="button"
                    data-prev
                    class="absolute inset-y-0 left-0 w-1/2 z-[4] cursor-w-resize flex items-center justify-start pl-3 md:pl-6"
                    aria-label="Page précédente"
                    data-i18n-attr="aria-label:process.flipbook.prev"
                  >
                    <span class="inline-flex items-center justify-center w-9 h-9 md:w-11 md:h-11 rounded-full bg-white/85 backdrop-blur-sm text-[var(--color-ink)] shadow hover:bg-white transition">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 6l-6 6 6 6"/></svg>
                    </span>
                  </button>
                  <button
                    type="button"
                    data-next
                    class="absolute inset-y-0 right-0 w-1/2 z-[4] cursor-e-resize flex items-center justify-end pr-3 md:pr-6"
                    aria-label="Page suivante"
                    data-i18n-attr="aria-label:process.flipbook.next"
                  >
                    <span class="inline-flex items-center justify-center w-9 h-9 md:w-11 md:h-11 rounded-full bg-white/85 backdrop-blur-sm text-[var(--color-ink)] shadow hover:bg-white transition">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 6l6 6-6 6"/></svg>
                    </span>
                  </button>

                </div>
              ) : step.stack ? (
                <div
                  class:list={[
                    "md:aspect-[4/5] flex items-center justify-center bg-white px-6 md:px-10 py-0 md:py-14",
                    "order-2",
                    reversed ? "lg:order-2" : "lg:order-1",
                  ]}
                >
                  <div class:list={[
                    "relative",
                    step.landscape ? "w-[88%] aspect-[1.414/1]" : "w-[62%] aspect-[1/1.414]",
                  ]}>
                    {/* Fan-shaped stack — rotations pivot around bottom-center
                        so the back pages swing up-right while the front leans left,
                        like the A4 mockup reference. */}
                    {(() => {
                      // Layouts per stack size — back-to-front order.
                      const layoutsByCount = {
                        2: [
                          { tx:  9, ty: -3, rot:  4, isFront: false }, // back  — page-02
                          { tx: -2, ty:  1, rot: -4, isFront: true  }, // front — page-01
                        ],
                        4: [
                          { tx:  5, ty: -2, rot:  14, isFront: false },
                          { tx:  3, ty: -1, rot:   8, isFront: false },
                          { tx:  1, ty:  0, rot:   2, isFront: false },
                          { tx: -2, ty:  1, rot:  -6, isFront: true  },
                        ],
                      };
                      const layouts = layoutsByCount[step.stack.length] || layoutsByCount[4];
                      const offset = Math.max(0, layouts.length - step.stack.length);
                      return step.stack.map((src, idx) => {
                        const layout = layouts[offset + idx] || layouts[layouts.length - 1];
                        // Softer single drop-shadow matching the flipbook intensity.
                        const shadow = "drop-shadow(0 16px 24px rgba(0,0,0,0.10))";
                        return (
                          <img
                            src={src}
                            alt={`${step.alt} — page ${idx + 1}`}
                            loading="lazy"
                            class="absolute inset-0 w-full h-full object-cover bg-white"
                            style={`transform-origin: 50% 95%; transform: translate(${layout.tx}%, ${layout.ty}%) rotate(${layout.rot}deg); filter: ${shadow}; z-index: ${idx + 1};`}
                          />
                        );
                      });
                    })()}
                  </div>
                </div>
              ) : step.contained ? (
                <div
                  class:list={[
                    "aspect-[4/5] flex items-center justify-center bg-white px-6 md:px-10 py-8 md:py-10",
                    "order-2",
                    reversed ? "lg:order-2" : "lg:order-1",
                  ]}
                >
                  <img
                    src={step.image}
                    alt={step.alt}
                    loading="lazy"
                    class="max-w-full max-h-full object-contain"
                    style="filter: drop-shadow(0 18px 28px rgba(0,0,0,0.18)) drop-shadow(0 6px 10px rgba(0,0,0,0.10));"
                  />
                </div>
              ) : (
                <div
                  class:list={[
                    "aspect-[4/5] overflow-hidden bg-[var(--color-cream)]",
                    "order-2",
                    reversed ? "lg:order-2" : "lg:order-1",
                  ]}
                >
                  <img
                    src={step.image}
                    alt={step.alt}
                    loading="lazy"
                    class="w-full h-full object-cover"
                    onerror="this.style.background='linear-gradient(135deg,#e8d8c0,#c69d6a)';this.removeAttribute('src');"
                  />
                </div>
              )}

              {/* Text */}
              <div class:list={[
                "order-1",
                reversed ? "lg:order-1 lg:pr-8" : "lg:order-2 lg:pl-8",
                step.textOffset ?? "",
              ]}>
                <h3 class="processus-step-title font-display font-light text-[clamp(0.95rem,2.6vw,1.35rem)] leading-[1.25] text-[var(--color-ink)] text-balance flex flex-wrap items-baseline gap-x-1.5 sm:gap-x-2 !tracking-[0.1em]">
                  <span class="font-gilda tracking-normal">{step.n}</span>
                  <span class="font-gilda tracking-normal" aria-hidden="true">/</span>
                  <span data-i18n={`process.step.${i + 1}.title`}>
                    {step.title.split("&").map((part, idx, arr) => (
                      <>
                        {part}
                        {idx < arr.length - 1 && <span class="amp">&amp;</span>}
                      </>
                    ))}
                  </span>
                </h3>
                <svg
                  class="mt-8 hidden lg:block text-[var(--color-ink)]"
                  width="105"
                  height="12"
                  viewBox="0 0 90 10"
                  fill="currentColor"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  {/* horizontal line passing through the first sparkle */}
                  <line x1="0" y1="5" x2="55" y2="5" stroke-width="0.35" />
                  {/* 4-point sparkle through the line */}
                  <path d="M48 2.5 Q48.3 4.7 50.5 5 Q48.3 5.3 48 7.5 Q47.7 5.3 45.5 5 Q47.7 4.7 48 2.5 Z" stroke="none" />
                  {/* second sparkle */}
                  <path d="M65 2.5 Q65.3 4.7 67.5 5 Q65.3 5.3 65 7.5 Q64.7 5.3 62.5 5 Q64.7 4.7 65 2.5 Z" stroke="none" />
                  {/* third sparkle */}
                  <path d="M82 2.5 Q82.3 4.7 84.5 5 Q82.3 5.3 82 7.5 Q81.7 5.3 79.5 5 Q81.7 4.7 82 2.5 Z" stroke="none" />
                </svg>
                <p class="mt-6 lg:mt-6 text-[0.95rem] leading-[1.95] text-[var(--color-ink-soft)] max-w-md" data-i18n={`process.step.${i + 1}.body`}>
                  {step.body}
                </p>
              </div>
            </div>

            {/* Mobile/tablet only: 3-sparkle divider between this step's image and the next step */}
            {i < steps.length - 1 && (
              <div class="lg:hidden my-20 flex justify-center" aria-hidden="true">
                <svg
                  class="text-[var(--color-ink)]"
                  width="140"
                  height="14"
                  viewBox="0 0 140 10"
                  fill="currentColor"
                  stroke="currentColor"
                >
                  {/* centered horizontal line */}
                  <line x1="20" y1="5" x2="120" y2="5" stroke-width="0.35" />
                  {/* three 4-point sparkles evenly spaced through the line */}
                  <path d="M48 2 Q48.4 4.6 51 5 Q48.4 5.4 48 8 Q47.6 5.4 45 5 Q47.6 4.6 48 2 Z" stroke="none" />
                  <path d="M70 2 Q70.4 4.6 73 5 Q70.4 5.4 70 8 Q69.6 5.4 67 5 Q69.6 4.6 70 2 Z" stroke="none" />
                  <path d="M92 2 Q92.4 4.6 95 5 Q92.4 5.4 92 8 Q91.6 5.4 89 5 Q91.6 4.6 92 2 Z" stroke="none" />
                </svg>
              </div>
            )}
          </div>
        );
      })}
    </div>
  </section>

  {/* ───────────────────────── 5. CLOSING MANIFESTO + CTA ───────────────────────── */}
  <section class="bg-[#1A1A1A] text-white py-20 md:py-28 px-6">
    <div class="mx-auto max-w-[1320px]">
      <div class="grid grid-cols-12 gap-6 md:gap-10 items-center">
        {/* Left composite: tall portrait + small square offset bottom-right */}
        <div class="col-span-12 md:col-span-4 relative pb-8 md:pb-10">
          <div class="aspect-[3/4] overflow-hidden bg-white w-[64%]">
            <img
              src="/images/closing-main.jpg"
              alt="Détail composition"
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="aspect-[4/5] overflow-hidden bg-white absolute right-[2%] bottom-0 w-[50%]">
            <img
              src="/images/closing-small.jpg"
              alt="Plan de table"
              loading="lazy"
              class="w-full h-full object-cover object-top"
            />
          </div>
        </div>

        {/* Right: italic manifesto + CTA */}
        <div class="col-span-12 md:col-span-8 md:pl-6 mt-8 md:mt-0">
          <div class="w-fit max-w-full">
            <p class="font-italic-serif italic text-[1.4rem] sm:text-[1.7rem] md:text-[40px] leading-[1.4] md:leading-[1.3] text-white text-pretty" data-i18n="process.closing">
              Mon processus créatif allie écoute,<br class="hidden md:inline" />
              intuition et exigence esthétique, pour<br class="hidden md:inline" />
              concevoir une expérience sur mesure et<br class="hidden md:inline" />
              propre à votre histoire.
            </p>

            <div class="mt-10 md:mt-14 flex justify-end">
              <SparkLink
                href="/contact"
                label="Contactez-moi"
                i18nKey="process.closing.cta"
                arrowClass="h-[22px] w-[22px] md:h-[37px] md:w-[37px]"
                class="text-white !text-[0.8rem] md:!text-[18px] !tracking-[0.16em] md:!tracking-[0.2em] !gap-2 md:!gap-3"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  @media (max-width: 767px) {
    /* Match the ampersand height to the rest of the processus step title on mobile */
    h3 .amp {
      font-size: 1em;
      vertical-align: baseline;
    }
  }
</style>

<script>
  // Flipbook navigation — crossfade between pages, keyboard + click support.
  document.querySelectorAll<HTMLElement>("[data-flipbook]").forEach((root) => {
    const pages = Array.from(root.querySelectorAll<HTMLImageElement>("[data-page]"));
    const counter = root.querySelector<HTMLElement>("[data-counter]");
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-next]");
    let current = 0;

    function show(i: number) {
      const n = pages.length;
      const next = ((i % n) + n) % n;
      pages.forEach((p, idx) => {
        const active = idx === next;
        p.style.opacity = active ? "1" : "0";
        p.style.zIndex = active ? "2" : "1";
        p.style.pointerEvents = active ? "auto" : "none";
      });
      current = next;
      if (counter) counter.textContent = String(next + 1).padStart(2, "0");
    }

    prevBtn?.addEventListener("click", () => show(current - 1));
    nextBtn?.addEventListener("click", () => show(current + 1));

    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") { e.preventDefault(); show(current - 1); }
      if (e.key === "ArrowRight") { e.preventDefault(); show(current + 1); }
    });
  });
</script>
