---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";

// 17 "Temps forts" highlight photos, ordered by their appearance in Wix
const strip = [
  { src: "/images/portfolio-strip/01_3e933860.jpg", alt: "Salle de réception décorée" },
  { src: "/images/portfolio-strip/02_74179fa8.jpg", alt: "Domaine et voiture vintage" },
  { src: "/images/portfolio-strip/03_e633e2c6.jpg", alt: "Détail floral" },
  { src: "/images/portfolio-strip/04_6297cc8a.png", alt: "Composition graphique" },
  { src: "/images/portfolio-strip/05_41e5ab48.jpg", alt: "Mise en place" },
  { src: "/images/portfolio-strip/06_95d16cce.jpg", alt: "Cérémonie en extérieur" },
  { src: "/images/portfolio-strip/07_dce575f9.jpg", alt: "Détail scénographique" },
  { src: "/images/portfolio-strip/08_abe01ccb.jpg", alt: "Table dressée" },
  { src: "/images/portfolio-strip/09_06a401f7.jpg", alt: "Atmosphère lumineuse" },
  { src: "/images/portfolio-strip/10_990a1165.jpg", alt: "Décor floral" },
  { src: "/images/portfolio-strip/11_a37af623.jpg", alt: "Mariés portrait" },
  { src: "/images/portfolio-strip/12_4f08de47.jpg", alt: "Papeterie sur-mesure" },
  { src: "/images/portfolio-strip/13_f97907ca.jpg", alt: "Espace cocktail" },
  { src: "/images/portfolio-strip/14_b88c2457.jpg", alt: "Ambiance romantique" },
  { src: "/images/portfolio-strip/15_9392a4cb.jpg", alt: "Détail bouquet" },
  { src: "/images/portfolio-strip/16_d03e2066.jpg", alt: "Couple et décor" },
  { src: "/images/portfolio-strip/17_f9bdf9b5.jpg", alt: "Scénographie d'ensemble" },
];

const projects = [
  {
    href: "/portfolio/mt",
    img: "/images/portfolio-mt.jpg",
    alt: "Aperçu du mariage M+T au Château de Perron",
    title: "M+T, MARIAGE ÉLÉGANT",
    italic: "à la Française",
  },
  {
    href: "/portfolio/ef",
    img: "/images/portfolio-ef.jpg",
    alt: "Cérémonie outdoor pampas pour E+F",
    title: "E+F, MARIAGE MINIMALISTE",
    italic: "aux teintes de Madagascar",
  },
];
---

<Layout title="PORTFOLIO | Aritia Design" transparentHeader={true} darkFooter={false}>
  <PageHero
    image="/images/portfolio-hero.jpg"
    imageAlt="Domaine de réception avec fontaine"
    title="Portfolio"
    subtitleHtml="Des univers sur-mesure, raffiné<br />&amp; porteurs d'émotions"
  />

  {/* ───────────────────────── 2. ✦ TEMPS FORTS ✦ ───────────────────────── */}
  <section class="bg-white py-14 md:py-20 text-center">
    <div class="inline-block px-8 py-3 bg-[#1a1a1a] text-white text-[11px] tracking-[0.32em] uppercase">
      ✦ Temps forts ✦
    </div>
  </section>

  {/* ───────────────────────── 3. STRIP — horizontal infinite marquee ───────────────────────── */}
  <section class="bg-white pb-16 overflow-hidden">
    <div class="marquee relative w-full">
      <div class="marquee-track gap-3 md:gap-4 items-center" style="animation-duration: 30s;">
        {[...strip, ...strip].map((img, i) => (
          <div
            class="shrink-0 aspect-[3/4] h-[280px] md:h-[420px] lg:h-[500px] overflow-hidden bg-neutral-100"
            aria-hidden={i >= strip.length ? "true" : undefined}
          >
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              class="w-full h-full object-cover"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ───────────────────────── 4. SAVOIR-FAIRE + PROJETS ───────────────────────── */}
  <section class="bg-white px-6 py-20 md:py-28">
    <div class="mx-auto max-w-[1300px] grid md:grid-cols-2 gap-10 md:gap-20 items-center">
      {/* left: text block centered */}
      <div class="text-center">
        <h2 class="font-display text-[36px] md:text-[44px] leading-[1.4] tracking-wide text-[var(--color-ink)]">
          SAVOIR-FAIRE<br />
          <span class="font-italic-serif italic font-light">Élégance</span><br />
          HARMONIE<br />
          <span class="font-italic-serif italic font-light">Atmosphère</span><br />
          SUR-MESURE
        </h2>
        <p class="mt-10 text-[14px] leading-[1.9] text-[var(--color-ink-soft)] max-w-md mx-auto">
          Découvrez une sélection de mariages et d'événements
          soigneusement mis en lumière. Cliquez sur chaque titre pour
          explorer la galerie complète.
        </p>
      </div>

      {/* right: 2 stacked project cards */}
      <div class="space-y-10">
        {projects.map((p) => (
          <a href={p.href} class="block group">
            <div class="aspect-[4/3] overflow-hidden bg-neutral-200">
              <img
                src={p.img}
                alt={p.alt}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
            </div>
            <div class="mt-5 text-center">
              <p class="text-[12px] tracking-[0.32em] uppercase text-[var(--color-ink)]">{p.title}</p>
              <p class="mt-1 font-italic-serif italic text-[18px] text-[var(--color-ink-soft)]">{p.italic}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ───────────────────────── 5. CTA DARK (background = fireworks video) ───────────────────────── */}
  <section class="relative overflow-hidden text-white px-6 py-24 md:py-32 text-center">
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source src="/videos/feux-artifices.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/55"></div>

    <div class="relative">
      <h2 class="font-display text-[36px] md:text-[52px] leading-[1.2]">
        NON, <span class="font-italic-serif italic font-light">VOS RÊVES</span><br />
        NE SONT PAS TROP GRAND
      </h2>
      <a
        href="/contact"
        class="inline-block mt-12 px-12 py-4 border border-white text-[0.72rem] tracking-[0.32em] uppercase hover:bg-white hover:text-[var(--color-ink)] transition"
      >
        Créer mon univers
      </a>
    </div>
  </section>
</Layout>
