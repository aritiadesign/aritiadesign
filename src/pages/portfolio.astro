---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";

// 17 "Temps forts" highlight photos, ordered by their appearance in Wix
const strip = [
  { src: "/images/portfolio-strip/01_3e933860.jpg", alt: "Salle de réception décorée" },
  { src: "/images/portfolio-strip/02_74179fa8.jpg", alt: "Domaine et voiture vintage" },
  { src: "/images/portfolio-strip/03_e633e2c6.jpg", alt: "Détail floral" },
  { src: "/images/portfolio-strip/04_6297cc8a.jpg", alt: "Composition graphique" },
  { src: "/images/portfolio-strip/05_41e5ab48.jpg", alt: "Mise en place" },
  { src: "/images/portfolio-strip/06_95d16cce.jpg", alt: "Cérémonie en extérieur" },
  { src: "/images/portfolio-strip/07_dce575f9.jpg", alt: "Détail scénographique" },
  { src: "/images/portfolio-strip/08_abe01ccb.jpg", alt: "Table dressée" },
  { src: "/images/portfolio-strip/09_06a401f7.jpg", alt: "Atmosphère lumineuse" },
  { src: "/images/portfolio-strip/10_990a1165.jpg", alt: "Décor floral" },
  { src: "/images/portfolio-strip/11_a37af623.jpg", alt: "Mariés portrait" },
  { src: "/images/portfolio-strip/12_4f08de47.jpg", alt: "Papeterie sur-mesure" },
  { src: "/images/portfolio-strip/13_f97907ca.jpg", alt: "Espace cocktail" },
  { src: "/images/portfolio-strip/14_b88c2457.jpg", alt: "Ambiance romantique" },
  { src: "/images/portfolio-strip/15_9392a4cb.jpg", alt: "Détail bouquet" },
  { src: "/images/portfolio-strip/16_d03e2066.jpg", alt: "Couple et décor" },
  { src: "/images/portfolio-strip/17_f9bdf9b5.jpg", alt: "Scénographie d'ensemble" },
];

const projects = [
  {
    href: "/portfolio/mt",
    img: "/images/portfolio-mt.jpg",
    alt: "Aperçu du mariage M+T au Château de Perron",
    title: "M+T, MARIAGE ÉLÉGANT",
    italic: "à la Française",
    editorial: false,
    keyPrefix: "portfolio.project.mt",
  },
  {
    href: "/portfolio/hj",
    img: "/images/portfolio-hj.jpg",
    alt: "Décor romantique moderne pour H+J",
    title: "H+J, ROMANTISME MODERNE",
    italic: "avec un accent culturel",
    editorial: true,
    disabled: true,
    keyPrefix: "portfolio.project.hj",
  },
];

const leftProject = {
  href: "/portfolio/ef",
  img: "/images/portfolio-ef.jpg",
  alt: "Cérémonie outdoor pampas pour E+F",
  title: "E+F, MARIAGE MINIMALISTE",
  italic: "aux teintes de Madagascar",
  editorial: false,
  keyPrefix: "portfolio.project.ef",
};
---

<Layout
  title="Portfolio — Mariages & évènements raffinés | Aritia Design Toulouse"
  description="Portfolio de mariages haut de gamme et évènements d'exception conçus par Aritia Design à Toulouse, en Haute-Garonne et alentours. Décor, scénographie, design floral et papeterie."
  transparentHeader={true}
  darkFooter={false}
>
  <PageHero
    image="/images/portfolio-hero.jpg"
    imageAlt="Domaine de réception avec fontaine"
    title="Portfolio"
    titleKey="portfolio.hero.title"
    subtitleHtml="Des univers sur-mesure, raffiné<br class='show-mobile' />&amp; porteurs d'émotions"
    subtitleKey="portfolio.hero.subtitle"
  />

  {/* ───────────────────────── 2. ✦ TEMPS FORTS ✦ ───────────────────────── */}
  <section class="bg-white py-14 md:py-20 text-center">
    <div class="inline-block px-8 py-3 bg-[#1a1a1a] text-white text-[11px] tracking-[0.32em] uppercase" data-i18n="portfolio.label">
      ✦ Temps forts ✦
    </div>
  </section>

  {/* ───────────────────────── 3. STRIP — horizontal infinite marquee ───────────────────────── */}
  <section class="bg-white pb-16 overflow-hidden">
    <div class="marquee relative w-full" data-marquee>
      <div class="marquee-track gap-3 md:gap-4 items-center">
        {[...strip, ...strip].map((img, i) => (
          <button
            type="button"
            class="shrink-0 aspect-[3/4] h-[280px] md:h-[420px] lg:h-[500px] overflow-hidden bg-neutral-100 cursor-pointer block"
            aria-hidden={i >= strip.length ? "true" : undefined}
            aria-label={img.alt}
            tabindex={i < strip.length ? 0 : -1}
          >
            <img
              src={img.src}
              alt={img.alt}
              loading="eager"
              decoding="async"
              draggable="false"
              class="w-full h-full object-cover pointer-events-none select-none"
            />
          </button>
        ))}
      </div>
    </div>

    <script is:inline>
      (function () {
        const marquee = document.querySelector("section .marquee[data-marquee]");
        if (!marquee) return;
        const track = marquee.querySelector(".marquee-track");
        if (!track) return;

        const SPEED = matchMedia("(max-width: 767px)").matches ? 1.8 : 1; // px per frame (mobile faster)
        let paused = false;
        let resumeTimer;

        // Auto-advance scroll. Loop seamlessly: items are duplicated, so wrapping
        // back at half the track width is invisible to the eye.
        function tick() {
          if (!paused) {
            const half = track.scrollWidth / 2;
            if (half > 0) {
              marquee.scrollLeft += SPEED;
              if (marquee.scrollLeft >= half) marquee.scrollLeft -= half;
            }
          }
          requestAnimationFrame(tick);
        }
        if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
          requestAnimationFrame(tick);
        }

        const pause = () => { paused = true; clearTimeout(resumeTimer); };
        const scheduleResume = (delay) => {
          clearTimeout(resumeTimer);
          resumeTimer = setTimeout(() => { paused = false; }, delay);
        };

        // Desktop: pause on cursor enter, resume immediately on cursor leave.
        marquee.addEventListener("mouseenter", pause);
        marquee.addEventListener("mouseleave", () => {
          clearTimeout(resumeTimer);
          paused = false;
        });

        // Mouse wheel / trackpad horizontal scroll → pause briefly while user drives.
        marquee.addEventListener("wheel", () => {
          pause();
          scheduleResume(1500);
        }, { passive: true });

        // Touch: pause while finger is down, resume 2s after release.
        marquee.addEventListener("touchstart",  pause,                       { passive: true });
        marquee.addEventListener("touchend",    () => scheduleResume(2000),  { passive: true });
        marquee.addEventListener("touchcancel", () => scheduleResume(2000),  { passive: true });

        // Click an image → smooth-scroll to centre it.
        marquee.querySelectorAll("button").forEach((b) => {
          b.addEventListener("click", () => {
            pause();
            const rect = b.getBoundingClientRect();
            const mqRect = marquee.getBoundingClientRect();
            const target = marquee.scrollLeft + (rect.left - mqRect.left) - (mqRect.width - rect.width) / 2;
            marquee.scrollTo({ left: target, behavior: "smooth" });
            scheduleResume(2500);
          });
        });
      })();
    </script>
  </section>

  {/* ───────────────────────── 4. SAVOIR-FAIRE + PROJETS ───────────────────────── */}
  <section class="bg-white px-6 py-20 md:py-28">
    <div class="mx-auto max-w-[1300px] grid md:grid-cols-2 gap-10 md:gap-20 items-start">
      {/* left: text block centered */}
      <div class="text-center">
        <h2 class="font-display text-[38px] md:text-[44px] lg:text-[60px] leading-[1.3] md:leading-[1.4] tracking-wide text-[var(--color-ink)]" data-i18n="portfolio.savoir.h2">
          SAVOIR-FAIRE<br />
          <span class="font-italic-serif italic font-light">Élégance</span><br />
          HARMONIE<br />
          <span class="font-italic-serif italic font-light">Atmosphère</span><br />
          SUR-MESURE
        </h2>
        <p class="mt-6 md:mt-10 text-[14px] md:text-[16px] leading-[1.85] md:leading-[1.9] text-[var(--color-ink-soft)] max-w-md mx-auto" data-i18n="portfolio.savoir.p">
          Découvrez une sélection de mariages et d'évènements
          soigneusement mis en lumière. Cliquez sur chaque titre pour
          explorer la galerie complète.
        </p>

        <a href={leftProject.href} class="block group mt-12">
          <div class="aspect-[4/3] overflow-hidden bg-neutral-200">
            <img
              src={leftProject.img}
              alt={leftProject.alt}
              class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 ${leftProject.editorial ? "grayscale contrast-125 brightness-95" : ""}`}
            />
          </div>
          <div class="mt-5 text-center">
            <p class="inline-flex items-center gap-3 text-[12px] tracking-[0.32em] uppercase text-[var(--color-ink)]">
              <span data-i18n={`${leftProject.keyPrefix}.title`}>{leftProject.title}</span>
              <svg
                viewBox="0 0 40 40"
                class="w-[18px] h-[18px] shrink-0 transition-transform duration-500 group-hover:rotate-90"
                aria-hidden="true"
              >
                <line x1="20" y1="6" x2="20" y2="34" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                <line x1="6" y1="20" x2="34" y2="20" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
              </svg>
            </p>
          </div>
        </a>
      </div>

      {/* right: 2 stacked project cards, bottom-aligned with left column */}
      <div class="space-y-10 self-end">
        {projects.map((p) => (
          p.disabled ? (
            <div class="block cursor-default group" aria-disabled="true">
              <div class="relative aspect-[4/3] overflow-hidden bg-neutral-200">
                <img
                  src={p.img}
                  alt={p.alt}
                  class={`w-full h-full object-cover ${p.editorial ? "grayscale contrast-125 brightness-95" : ""}`}
                />
                <div class="absolute inset-0 bg-black/55 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center pointer-events-none">
                  <span class="font-italic-serif italic font-light text-white text-[32px] md:text-[40px] lg:text-[48px] leading-none" data-i18n="portfolio.project.soon">à venir</span>
                </div>
              </div>
              <div class="mt-5 text-center">
                <p class="text-[12px] tracking-[0.32em] uppercase text-[var(--color-ink)]" data-i18n={`${p.keyPrefix}.title`}>{p.title}</p>
              </div>
            </div>
          ) : (
            <a href={p.href} class="block group">
              <div class="aspect-[4/3] overflow-hidden bg-neutral-200">
                <img
                  src={p.img}
                  alt={p.alt}
                  class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 ${p.editorial ? "grayscale contrast-125 brightness-95" : ""}`}
                />
              </div>
              <div class="mt-5 text-center">
                <p class="inline-flex items-center gap-3 text-[12px] tracking-[0.32em] uppercase text-[var(--color-ink)]">
                  <span data-i18n={`${p.keyPrefix}.title`}>{p.title}</span>
                  <svg
                    viewBox="0 0 40 40"
                    class="w-[18px] h-[18px] shrink-0 transition-transform duration-500 group-hover:rotate-90"
                    aria-hidden="true"
                  >
                    <line x1="20" y1="6" x2="20" y2="34" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                    <line x1="6" y1="20" x2="34" y2="20" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
                  </svg>
                </p>
              </div>
            </a>
          )
        ))}
      </div>
    </div>
  </section>

  {/* ───────────────────────── 5. CTA DARK (background = fireworks video) ───────────────────────── */}
  <section class="relative overflow-hidden text-white px-6 py-24 md:py-32 text-center">
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    >
      <source src="/videos/feux-artifices.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/55"></div>

    <div class="relative">
      <h2 class="font-display text-[36px] md:text-[44px] lg:text-[52px] leading-[1.2]" data-i18n="portfolio.cta.h2">
        NON, <span class="font-italic-serif italic font-light">VOS RÊVES</span><br />
        NE SONT PAS TROP GRAND
      </h2>
      <a
        href="/contact"
        class="inline-block mt-12 px-12 py-4 border border-white text-[0.72rem] tracking-[0.32em] uppercase hover:bg-white hover:text-[var(--color-ink)] transition"
        data-i18n="portfolio.cta.btn"
      >
        Créer mon univers
      </a>
    </div>
  </section>
</Layout>
