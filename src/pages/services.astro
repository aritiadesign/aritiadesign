---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SparkLink from "../components/SparkLink.astro";

const tiers = [
  {
    title: "L'EXCEPTION",
    italic: "design intégral",
    price: "À partir de 6 000 €",
    scope: "≤50 invités, un espace principal, fleurs de saison, décor sourcé.<br />DA globale incluse (valeur 1 500 €).",
    bullets: [
      "Moodboard complet, palette de couleurs et charte typographique",
      "Papeterie essentielle : faire-part, menus et plan de table",
      "Floral intimiste : bouquet de la mariée, 5 centres de table et arche cérémonie",
      "Décor & scénographie : sélection et mise en place du mobilier, vaisselle et objets décoratifs sourcés",
      "3 réunions de travail et 1 visite du lieu de réception",
      "Présence le jour J (10 heures) avec installation et démontage J+1",
    ],
    desc: "L'expérience la plus aboutie : Aritia Design, votre interlocuteur unique pour orchestrer l'intégralité de votre célébration. <span class=\"hidden md:inline\">De la première inspiration à la dernière fleur posée, nous prenons en charge chaque dimension esthétique de votre journée. </span>Vous validez les concepts, nous réalisons le reste. — Structures et décor sur-mesure proposés en option selon vos envies.",
    image: "/images/services-design-global.jpg",
    accent: "burgundy",
  },
  {
    title: "PACK ATMOSPHÈRE",
    italic: "décor & papeterie",
    price: "À partir de 3 600 €",
    scope: "≤50 invités, un espace principal, décor sourcé.<br />Économie de 400 € vs prestations séparées.",
    bullets: [
      "Direction artistique commune : palette de couleurs et charte typographique partagées entre papier et décor",
      "Papeterie essentielle : faire-part, menus et plan de table",
      "Décor & scénographie : sélection et mise en place du mobilier, vaisselle et objets décoratifs sourcés",
      "2 réunions de travail et 1 visite du lieu de réception",
      "Installation le jour J et démontage J+1",
    ],
    desc: "Pensé pour une identité visuelle parfaitement alignée. Votre papeterie, votre signalétique et votre décor s'articulent comme un ensemble unique. — Structures sur-mesure proposées en option selon vos envies.",
    image: "/images/services-decor.jpg",
    accent: "ink",
  },
  {
    title: "DIRECTION ARTISTIQUE",
    italic: "seule",
    price: "À partir de 1 500 €",
    scope: "Déductible à 100 % en cas de signature d'un pack sous 60 jours",
    bullets: [
      "Moodboard complet de votre univers de mariage",
      "Palette de couleurs, choix des matières et textures",
      "Planches d'inspiration scénographique",
      "Charte typographique et recommandations graphiques",
      "Liste de prestataires recommandés",
      "2 réunions de travail",
      "Dossier complet remis en PDF",
    ],
    desc: "Vous repartez avec notre vision et l'orchestrez avec vos propres prestataires. Une option idéale pour celles et ceux qui souhaitent une signature artistique forte sans formule complète.",
    image: "/images/flipbook-investissement/01.jpg",
    flipbook: Array.from({ length: 23 }, (_, i) =>
      `/images/flipbook-investissement/${String(i + 1).padStart(2, "0")}.jpg`
    ),
    // Per-page watermark opacity (index 0 = cover, already branded → hide).
    // Tweak any index to override the 0.06 default for that page.
    watermarkOpacities: { 0: 0 } as Record<number, number>,
    accent: "ink",
  },
];

const aLaCarte = [
  {
    title: "Papeterie fine",
    price: "à partir de 800 €",
    scope: "≤50 invités, faire-part et menus",
    bullets: [
      "Concept graphique et palette typographique",
      "2 maquettes et bon à tirer (BAT) final",
      "Faire-part recto-verso",
      "Menus de table individuels",
      "Plan de table imprimé",
      "Impression, façonnage et livraison",
    ],
  },
  {
    title: "Design floral artistique",
    price: "à partir de 2 700 €",
    scope: "≤50 invités, fleurs de saison, un espace",
    bullets: [
      "Moodboard floral et palette de variétés",
      "Sourcing fleurs (grossiste / producteur local)",
      "Bouquet de la mariée",
      "5 centres de table simples",
      "Arche cérémonie minimaliste",
      "Composition en atelier et installation jour J",
    ],
  },
  {
    title: "Décor & scénographie",
    price: "à partir de 3 200 €",
    scope: "≤50 invités, un espace principal",
    bullets: [
      "Concept décoratif et plan de scénographie",
      "Sélection et location du mobilier",
      "Vaisselle, verrerie et objets décoratifs sourcés",
      "Mise en scène le jour J",
      "Démontage et reprise J+1",
    ],
  },
];

const included = [
  "Premier échange et entretien découverte",
  "Conception artistique adaptée à votre univers",
  "Devis détaillé, transparent et personnalisé",
  "Coordination de votre projet jusqu'au jour J",
  "Suivi attentif à chaque étape",
];

const modalites = [
  { step: "30 %", label: "À la signature", desc: "Acompte non remboursable réservant votre date" },
  { step: "40 %", label: "À J–90", desc: "Lancement de la production et des commandes" },
  { step: "30 %", label: "À J–15", desc: "Solde avant l'installation finale" },
];

const faqs = [
  {
    n: "01.",
    q: "ÊTES-VOUS PRÉSENTS LE JOUR J ?",
    a: "Oui, pour toutes nos formules avec exécution (l'Exception et Pack Atmosphère). Nous sommes présents de l'installation au démontage J+1 : nous orchestrons l'arrivée des prestataires, supervisons la mise en place et veillons à ce que chaque détail reflète fidèlement la direction artistique imaginée ensemble. Vous vivez votre célébration sereinement, sans avoir à gérer la logistique. Pour la Direction Artistique seule, vous repartez avec notre vision et l'orchestrez avec vos propres prestataires.",
  },
  {
    n: "02.",
    q: "QUELLE EST LA DIFFÉRENCE ENTRE VOS PRESTATIONS ET CELLES D'UN WEDDING PLANNER ?",
    a: "Notre rôle couvre la création artistique de votre mariage (univers visuel, scénographie, design floral, papeterie) et la coordination des prestataires qui exécutent cette vision (mobilier, éclairage, vaisselle, location décor...), tandis que le wedding planner orchestre l'organisation globale (planning, budget, traiteur, photographe, musique, lieu...). Les deux métiers sont complémentaires : l'un assure la fluidité organisationnelle, l'autre sublime l'expérience visuelle.",
  },
  {
    n: "03.",
    q: "OÙ OPÉREZ-VOUS ?",
    a: "Notre agence est basée à Toulouse et intervient principalement en Haute-Garonne. Au-delà, nous nous déplaçons dans toute la France et à l'étranger selon les projets, avec des frais de déplacement intégrés au devis pour une totale transparence.",
  },
  {
    n: "04.",
    q: "QUEL EST LE BON MOMENT POUR VOUS CONTACTER ?",
    a: "Les délais idéaux varient selon la formule choisie et l'ampleur du projet :<br /><br />— Pack L'Exception : 10 à 12 mois en amont (univers complet, sourcing des prestataires, coordination de la production).<br /><br />— Pack Atmosphère : 6 à 8 mois sont généralement suffisants.<br /><br />— Direction Artistique seule : à partir de 4 mois.<br /><br />Pour les évènements d'envergure (scénographie complexe, grande capacité), nous recommandons d'anticiper davantage. Nous restons toutefois flexibles sur des délais plus courts selon nos disponibilités du moment.",
  },
];
---

<Layout
  title="Services — Aritia Design Toulouse"
  description="Découvrez les niveaux d'engagement d'Aritia Design : Direction Artistique Intégrale, Pack Atmosphère, Direction Artistique seule et prestations à la carte — papeterie, floral, décor & scénographie. Sur devis personnalisé."
  transparentHeader={true}
>
  <PageHero
    image="/images/services-hero.jpg"
    imageAlt="Direction artistique"
    titleHtml="Services"
    titleKey="investment.hero.title"
    subtitleHtml="Chaque collaboration est unique.<br />Voici les niveaux d'engagement <br class='show-mobile' />que nous proposons."
    subtitleKey="investment.hero.subtitle"
  />

  {/* ───────────────────────── 2. INTRO ───────────────────────── */}
  <section class="bg-white px-6 py-24 md:py-32 text-center">
    <h2 class="font-display font-normal text-[28px] md:text-[36px] tracking-[0.06em] leading-[1.4] text-[var(--color-ink)]" data-i18n="investment.intro.h2">
      UN ENGAGEMENT À LA HAUTEUR<br />
      DE VOTRE ÉVÈNEMENT
    </h2>
  </section>

  {/* ───────────────────────── 3. NOTRE ENGAGEMENT ───────────────────────── */}
  <section class="bg-white px-6 pb-20 md:pb-28">
    <div class="mx-auto max-w-[1100px] grid lg:grid-cols-2 gap-8 lg:gap-12 items-start text-center lg:text-left">
      <div>
        <h3 class="font-display text-[44px] md:text-[48px] lg:text-[60px] leading-none tracking-wide" data-i18n="investment.value.h3">
          NOTRE<br />
          <span class="font-italic-serif italic">Engagement</span>
        </h3>
      </div>
      <div class="max-w-md mx-auto lg:mx-0 text-left text-pretty text-[14px] md:text-[16px] leading-[1.75] md:leading-[1.9] text-[var(--color-ink-soft)]">
        <p data-i18n="investment.value.p">
          Choisir Aritia Design, c'est confier votre célébration à un
          savoir-faire engagé et à une vraie culture du détail. Nous
          traduisons vos attentes de manière juste pour créer un
          événement unique, qui vous ressemble, et offrir à vos invités
          un moment mémorable.
        </p>
      </div>
    </div>
  </section>

  {/* ───────────────────────── 4. TIERS — CARTES PACKS ───────────────────────── */}
  <section class="bg-white pb-24 md:pb-36 md:px-6">
    <style is:global>
      .tiers-carousel::-webkit-scrollbar { display: none; }
      .tiers-carousel { scrollbar-width: none; -webkit-overflow-scrolling: touch; }
      @media (max-width: 767px) {
        .tier-card { transition: opacity 0.35s ease, transform 0.35s ease; opacity: 0.55; transform: scale(0.94); transform-origin: center; }
        .tier-card[data-active="true"] { opacity: 1; transform: scale(1); }
        .tier-scope br { display: none; }
      }
    </style>
    <div class="tiers-carousel mx-auto max-w-[1300px] flex md:block overflow-x-auto md:overflow-x-visible snap-x snap-mandatory md:snap-none gap-4 md:gap-0 md:space-y-20 lg:space-y-28 px-[10vw] md:px-0 pb-2 md:pb-0">
      {tiers.map((tier, i) => {
        const cardBg = tier.accent === "burgundy" ? "#640613" : "#1A1A1A";
        return (
          <article
            class="tier-card snap-center shrink-0 w-[80vw] md:w-auto grid lg:grid-cols-2 gap-0 overflow-hidden"
            style={`background-color: ${cardBg};`}
            data-active={i === 0 ? "true" : "false"}
          >
            {/* Image — static or flipbook */}
            {tier.flipbook ? (
              <div class="order-1 lg:order-1 lg:flex lg:flex-col lg:justify-center lg:py-12 lg:pl-12">
              <div
                class="flipbook aspect-[1587/1300] relative bg-[#1A1A1A] w-full overflow-hidden select-none group"
                data-flipbook
                tabindex="0"
                aria-label={`Flipbook ${tier.title} — utilisez les flèches gauche / droite pour naviguer`}
              >
                {tier.flipbook.map((src, idx) => {
                  const watermarkOpacity = tier.watermarkOpacities?.[idx] ?? 0.06;
                  return (
                    <div
                      data-page={idx}
                      class="absolute inset-0 transition-opacity duration-500 ease-out"
                      style={`opacity: ${idx === 0 ? 1 : 0}; z-index: ${idx === 0 ? 2 : 1}; pointer-events: ${idx === 0 ? "auto" : "none"};`}
                    >
                      <img
                        src={src}
                        alt={`${tier.title} — page ${idx + 1}`}
                        loading={idx < 2 ? "eager" : "lazy"}
                        class="absolute inset-0 w-full h-full object-contain"
                      />
                      {watermarkOpacity > 0 && (
                        <img
                          src="/images/watermark-ad.svg"
                          alt=""
                          aria-hidden="true"
                          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2/3 max-w-[420px] pointer-events-none select-none"
                          style={`opacity: ${watermarkOpacity}; filter: invert(1);`}
                        />
                      )}
                    </div>
                  );
                })}
                <button
                  type="button"
                  data-prev
                  class="absolute inset-y-0 left-0 w-1/2 z-[4] cursor-w-resize flex items-center justify-start pl-3 md:pl-6"
                  aria-label="Page précédente"
                >
                  <span class="inline-flex items-center justify-center w-9 h-9 md:w-11 md:h-11 rounded-full bg-white/85 backdrop-blur-sm text-[var(--color-ink)] shadow hover:bg-white transition">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 6l-6 6 6 6"/></svg>
                  </span>
                </button>
                <button
                  type="button"
                  data-next
                  class="absolute inset-y-0 right-0 w-1/2 z-[4] cursor-e-resize flex items-center justify-end pr-3 md:pr-6"
                  aria-label="Page suivante"
                >
                  <span class="inline-flex items-center justify-center w-9 h-9 md:w-11 md:h-11 rounded-full bg-white/85 backdrop-blur-sm text-[var(--color-ink)] shadow hover:bg-white transition">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 6l6 6-6 6"/></svg>
                  </span>
                </button>
              </div>
              </div>
            ) : (
              <div class="aspect-[4/3] lg:aspect-auto relative bg-[#0e0e0e] order-1 lg:order-1 overflow-hidden">
                <img
                  src={tier.image}
                  alt={tier.title}
                  class="absolute inset-0 w-full h-full object-cover"
                  loading="lazy"
                  onerror="this.style.background='linear-gradient(135deg,#2a2a2a,#1a1a1a)';this.removeAttribute('src');"
                />
              </div>
            )}

            {/* Texte */}
            <div class="p-7 md:p-14 lg:p-16 text-white flex flex-col justify-center order-2 lg:order-2">
              <h3 class="font-display leading-[1.1] tracking-wide text-[26px] md:text-[40px] lg:text-[48px]">
                <span data-i18n={`investment.tier.${i}.title`}>{tier.title}</span>
                {tier.italic && <> <span class="font-italic-serif italic font-light" data-i18n={`investment.tier.${i}.italic`}>{tier.italic.split("&").map((part, idx, arr) => (<>{part}{idx < arr.length - 1 && <span class="amp">&amp;</span>}</>))}</span></>}
              </h3>
              <p class="mt-6 md:mt-8 text-[14px] md:text-[16px] leading-[1.8] text-white/90 max-w-md" data-i18n={`investment.tier.${i}.desc`} set:html={tier.desc} />
              <p class="mt-7 md:mt-10 text-[12px] md:text-[15px] tracking-[0.22em] uppercase lining-nums tabular-nums text-white/95" data-i18n={`investment.tier.${i}.price`}>{tier.price}</p>
              {tier.scope && (
                <p
                  class="tier-scope mt-3 text-[10px] md:text-[16px] leading-[1.5] italic tracking-[0.3px] md:tracking-[0.5px] text-white/75"
                  style="font-variant-numeric: lining-nums tabular-nums; font-feature-settings: 'lnum' 1, 'tnum' 1;"
                  data-i18n={`investment.tier.${i}.scope`}
                  set:html={tier.scope}
                ></p>
              )}

              <details class="group mt-7 md:mt-10 border-t border-white/15 pt-4">
                <summary class="cursor-pointer list-none flex items-center justify-between gap-3 text-[11px] md:text-[15px] tracking-[0.18em] md:tracking-[0.22em] uppercase text-white/90">
                  <span class="whitespace-nowrap" data-i18n="investment.included.summary">✦ Compris dans l'expérience</span>
                  <span class="text-[18px] leading-none transition-transform group-open:rotate-45 shrink-0">+</span>
                </summary>
                <ul class="mt-5 space-y-2 text-[14px] md:text-[16px] leading-[1.65] text-white/85">
                  {tier.bullets.map((b, idx) => (
                    <li class="flex gap-2.5 items-start">
                      <span aria-hidden="true" class="inline-block w-[3px] h-[3px] rounded-full bg-current mt-[9px] shrink-0"></span>
                      <span data-i18n={`investment.tier.${i}.b${idx}`}>{b}</span>
                    </li>
                  ))}
                </ul>
                <a
                  href="/contact"
                  class:list={[
                    "inline-block mt-12 px-10 py-3 border border-white/60 text-[11px] tracking-[0.32em] uppercase text-white/95 transition",
                    tier.accent === "burgundy"
                      ? "hover:bg-[#1A1A1A] hover:text-white hover:border-[#1A1A1A]"
                      : "hover:bg-white hover:text-[var(--color-ink)]",
                  ]}
                  data-i18n="investment.tier.cta"
                >
                  Demander un devis
                </a>
              </details>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  {/* ───────────────────────── 5. À LA CARTE ───────────────────────── */}
  <section class="bg-white px-6 py-24 md:py-32 relative overflow-hidden">
    {/* Decorative side photos — desktop only */}
    <div class="hidden lg:block pointer-events-none select-none">
      <img src="/images/alacarte-left.jpg" alt="" aria-hidden="true" class="absolute top-[6%] left-10 w-[285px] xl:w-[345px] aspect-[3/4] object-cover" />
      <img src="/images/gallery/02.jpg" alt="" aria-hidden="true" class="absolute bottom-[8%] right-0 w-[285px] xl:w-[345px] aspect-[3/4] object-cover" />
    </div>
    <div class="mx-auto max-w-[1100px] text-center relative">
      <div class="inline-block px-8 py-3 bg-[#1a1a1a] text-white text-[11px] tracking-[0.32em] uppercase" data-i18n="investment.alacarte.label">
        ✦ À la carte ✦
      </div>
      <h2 class="mt-12 font-display font-normal text-[40px] md:text-[52px] lg:text-[64px] leading-[1.1] text-[var(--color-ink)]" data-i18n="investment.alacarte.h2">
        <span class="tracking-normal">Une</span> <span class="font-italic-serif italic font-light">prestation</span>,<br />
        <span class="tracking-normal">un</span> <span class="font-italic-serif italic font-light">univers</span>
      </h2>
      <p class="mt-10 text-[14px] md:text-[16px] leading-[1.9] text-[var(--color-ink-soft)] max-w-xl mx-auto" data-i18n="investment.alacarte.intro">
        Pour celles et ceux qui souhaitent confier une partie précise
        de leur évènement. Chaque prestation inclut son concept
        artistique et son exécution complète.
      </p>

      <div class="mt-16 max-w-2xl mx-auto divide-y divide-[var(--color-ink)]/15">
        {aLaCarte.map((item, i) => (
          <details class="group py-6 text-left">
            <summary class="cursor-pointer list-none flex items-baseline justify-between gap-6">
              <div class="flex items-baseline gap-3 md:gap-4">
                <span aria-hidden="true" class="text-[20px] md:text-[26px] leading-none font-light text-[var(--color-ink)] transition-transform duration-300 group-open:rotate-45 shrink-0">+</span>
                <span class="font-display text-[18px] md:text-[22px] text-[var(--color-ink)]" data-i18n={`investment.alacarte.${i}.title`}>{item.title.split("&").map((part, idx, arr) => (<>{part}{idx < arr.length - 1 && <span class="amp">&amp;</span>}</>))}</span>
              </div>
              <span class="tracking-[0.5px] text-[18px] md:text-[24px] text-[var(--color-ink-soft)] whitespace-nowrap" style="font-family: 'Noto Serif', Georgia, serif; font-style: italic;" data-i18n={`investment.alacarte.${i}.price`}>{item.price}</span>
            </summary>
            {item.scope && (
              <p class="mt-2 ml-9 md:ml-11 text-[14px] md:text-[16px] leading-[1.55] font-baskerville tracking-[0.5px] text-[var(--color-muted)]" data-i18n={`investment.alacarte.${i}.scope`}>{item.scope}</p>
            )}
            <div class="mt-5 ml-9 md:ml-11 flex flex-col md:flex-row md:items-center md:gap-10">
              <ul class="space-y-2 text-[13px] md:text-[14px] leading-[1.6] text-[var(--color-ink-soft)] flex-1">
                {item.bullets.map((b, idx) => (
                  <li class="flex gap-2.5 items-start">
                    <span aria-hidden="true" class="inline-block w-[3px] h-[3px] rounded-full bg-current mt-[9px] shrink-0"></span>
                    <span data-i18n={`investment.alacarte.${i}.b${idx}`}>{b}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-6 md:mt-0 md:mr-6 md:w-[145px] flex md:justify-center self-start md:self-center">
                <a
                  href="/contact"
                  class="inline-block px-6 py-3 border border-[var(--color-ink)] text-[10px] md:text-[11px] tracking-[0.32em] uppercase text-[var(--color-ink)] hover:bg-[var(--color-ink)] hover:text-white transition whitespace-nowrap"
                  data-i18n={`investment.alacarte.${i}.cta`}
                >
                  Réserver
                </a>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  {/* ───────────────────────── 6. CHAQUE COLLABORATION COMPREND ───────────────────────── */}
  <section class="bg-white px-6 py-24 md:py-32 overflow-x-hidden">
    <div class="mx-auto max-w-[1200px] grid md:grid-cols-2 gap-14 md:gap-20 items-stretch w-full">
      <div class="relative order-2 md:order-1 md:h-full md:min-h-[460px]">
        <div class="h-[400px] md:h-full bg-cream overflow-hidden">
          <img
            src="/images/about-dining.jpg"
            alt="Table dressée raffinée"
            class="w-full h-full object-cover"
            onerror="this.style.background='linear-gradient(135deg,#e8d8c0,#c69d6a)';this.removeAttribute('src');"
          />
        </div>
      </div>

      <div class="order-1 md:order-2 flex flex-col justify-center">
        <h2 class="text-center md:text-left font-display text-[40px] md:text-[48px] lg:text-[56px] leading-[1.1] tracking-wide text-[var(--color-ink)] mb-10" data-i18n="investment.included.h2">
          CHAQUE COLLABORATION<br />
          <span class="font-italic-serif italic font-light">comprend</span>
        </h2>
        <ul class="space-y-4 text-[15px] md:text-[16px] leading-[1.8] text-[var(--color-ink-soft)] max-w-md mx-auto md:mx-0">
          {included.map((item, i) => (
            <li class="flex gap-4 items-start">
              <span aria-hidden="true" class="text-[var(--color-ink)] mt-1">✦</span>
              <span data-i18n={`investment.included.item.${i}`}>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* ───────────────────────── 7. MODALITÉS DE PAIEMENT (parallax) ───────────────────────── */}
  <section
    class="relative text-white px-6 py-24 md:py-32 text-center bg-cover bg-center md:bg-fixed"
    style="background-image: url('/images/about-marble.jpg');"
  >
    <div class="absolute inset-0 bg-black/65"></div>
    <div class="relative mx-auto max-w-[1100px]">
