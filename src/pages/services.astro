<script>
  // Flipbook navigation — crossfade between pages, keyboard + click support.
  document.querySelectorAll<HTMLElement>("[data-flipbook]").forEach((root) => {
    const pages = Array.from(root.querySelectorAll<HTMLElement>("[data-page]"));
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-next]");
    let current = 0;

    function show(i: number) {
      const n = pages.length;
      const next = ((i % n) + n) % n;
      pages.forEach((p, idx) => {
        const active = idx === next;
        p.style.opacity = active ? "1" : "0";
        p.style.zIndex = active ? "2" : "1";
        p.style.pointerEvents = active ? "auto" : "none";
      });
      current = next;
    }

    prevBtn?.addEventListener("click", () => show(current - 1));
    nextBtn?.addEventListener("click", () => show(current + 1));

    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") { e.preventDefault(); show(current - 1); }
      if (e.key === "ArrowRight") { e.preventDefault(); show(current + 1); }
    });
  });

  // Mobile carousel: mark the tier card whose center is closest to the viewport center as active.
  const tiersCarousel = document.querySelector<HTMLElement>(".tiers-carousel");
  if (tiersCarousel) {
    const cards = Array.from(tiersCarousel.querySelectorAll<HTMLElement>(".tier-card"));
    const update = () => {
      const carouselRect = tiersCarousel.getBoundingClientRect();
      const centerX = carouselRect.left + carouselRect.width / 2;
      let bestIdx = 0;
      let bestDelta = Infinity;
      cards.forEach((card, i) => {
        const rect = card.getBoundingClientRect();
        const cardCenter = rect.left + rect.width / 2;
        const delta = Math.abs(cardCenter - centerX);
        if (delta < bestDelta) { bestDelta = delta; bestIdx = i; }
      });
      cards.forEach((c, i) => c.setAttribute("data-active", i === bestIdx ? "true" : "false"));
    };
    tiersCarousel.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update);
    update();
  }
</script>
