---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";

// Web3Forms access key — get yours at https://web3forms.com (free, unlimited)
const WEB3FORMS_KEY = "8de1adb6-676c-48db-8d77-490f7ee76c05";

// Show a thank-you state when ?sent=1 is in the URL (Web3Forms redirects here after submission)
const sent = Astro.url.searchParams.get("sent") === "1";
---

<Layout
  title="Contact — Aritia Design | Wedding Designer Toulouse"
  description="Contactez Aritia pour concevoir votre mariage ou événement sur-mesure à Toulouse, en Haute-Garonne. Réservez un premier échange pour partager votre vision."
  transparentHeader={true}
>
  <PageHero
    image="/images/contact-hero.jpg"
    imageAlt="Plafond aux poutres"
    title="Contact"
    subtitleHtml="Vous rêver d'un mariage ou d'un événement&nbsp;<br />qui vous ressemble&nbsp;?"
  />

  {/* ───────────────────────── 2. FORM ───────────────────────── */}
  <section class="bg-white px-6 py-20 md:py-28">
    <div class="mx-auto max-w-[1200px] grid md:grid-cols-2 gap-12 md:gap-16">
      {/* left: image + NOTES */}
      <div class="space-y-8">
        <div class="aspect-[4/5] overflow-hidden">
          <img
            src="/images/contact-flower.jpg"
            alt="Gros plan fleurs rouges"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="bg-[#1a1a1a] text-white p-8 md:p-10">
          <p class="font-display tracking-[0.28em] uppercase text-[14px] text-white/65">Notes</p>
          <p class="mt-5 text-[14px] leading-[1.9] text-white/85">
            Merci de remplir ce formulaire avec soin. Je reviendrai
            vers vous dans les 48 heures ouvrées afin de planifier un
            premier rendez-vous téléphonique, en visio ou en
            présentiel.
          </p>
          <p class="mt-5 text-[14px] leading-[1.9] text-white/85">
            Vous pouvez aussi m'écrire directement à l'adresse
            suivante&nbsp;:
            <a
              href="mailto:contact@aritiadesign.com"
              class="block mt-2 underline underline-offset-4 hover:opacity-70 transition"
            >contact@aritiadesign.com</a>
          </p>
        </div>
      </div>

      {/* right: form */}
      <div>
        <h2 class="font-display text-[44px] md:text-[60px] leading-[1] tracking-wide text-[var(--color-ink)]">
          FAISONS<br />CONNAISSANCE
        </h2>
        <p class="mt-8 text-[14px] leading-[1.9] text-[var(--color-ink-soft)] max-w-md">
          Votre histoire mérite une attention toute particulière, un
          regard sensible, et une mise en scène à la hauteur de vos
          émotions. Je serais honorée de vous accompagner dans la
          création d'un univers qui vous ressemble.
        </p>

        {sent && (
          <div class="mt-10 p-6 bg-[#f7f5f1] border border-[var(--color-ink)]/10 text-[14px] leading-[1.9] text-[var(--color-ink-soft)]">
            <p class="font-display text-[20px] text-[var(--color-ink)] mb-2">Merci&nbsp;!</p>
            <p>Votre demande a bien été envoyée. Je reviens vers vous sous 48&nbsp;h ouvrées.</p>
          </div>
        )}

        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="mt-10 space-y-7"
        >
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="Nouveau message — Aritia Design" />
          <input type="hidden" name="from_name" value="Site Aritia Design" />
          <input type="hidden" name="redirect" value={new URL("/contact?sent=1", Astro.site ?? Astro.url).toString()} />
          {/* Honeypot — bots fill this, real users don't */}
          <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
          <div class="border-b border-black/15 pb-1">
            <label class="sr-only" for="f-name">Nom &amp; Prénom</label>
            <input
              id="f-name"
              type="text"
              name="Nom & Prénom"
              required
              placeholder="NOM & PRÉNOM *"
              class="w-full bg-transparent text-[14px] tracking-[0.02em] placeholder:text-[12px] placeholder:tracking-[0.22em] placeholder:uppercase placeholder-[var(--color-muted)] focus:outline-none py-3"
            />
          </div>
          <div class="border-b border-black/15 pb-1">
            <label class="sr-only" for="f-email">Email</label>
            <input
              id="f-email"
              type="email"
              name="Email"
              required
              placeholder="E-MAIL *"
              class="w-full bg-transparent text-[14px] tracking-[0.02em] placeholder:text-[12px] placeholder:tracking-[0.22em] placeholder:uppercase placeholder-[var(--color-muted)] focus:outline-none py-3"
            />
          </div>
          <div class="border-b border-black/15 pb-1">
            <label class="sr-only" for="f-phone">Téléphone</label>
            <input
              id="f-phone"
              type="tel"
              name="Téléphone"
              placeholder="🇫🇷 TÉLÉPHONE"
              class="w-full bg-transparent text-[14px] tracking-[0.02em] placeholder:text-[12px] placeholder:tracking-[0.22em] placeholder:uppercase placeholder-[var(--color-muted)] focus:outline-none py-3"
            />
          </div>
          <div class="border-b border-black/15 pb-1">
            <label class="sr-only" for="f-date">Date</label>
            <input
              id="f-date"
              type="date"
              name="Date"
              required
              placeholder="DATE DE L'ÉVÈNEMENT *"
              class="w-full bg-transparent text-[14px] tracking-[0.02em] text-[var(--color-muted)] focus:outline-none py-3"
            />
          </div>
          <div class="border-b border-black/15 pb-1">
            <label class="sr-only" for="f-location">Lieu</label>
            <input
              id="f-location"
              type="text"
              name="Lieu"
              required
              placeholder="LIEU DE L'ÉVÈNEMENT *"
              class="w-full bg-transparent text-[14px] tracking-[0.02em] placeholder:text-[12px] placeholder:tracking-[0.22em] placeholder:uppercase placeholder-[var(--color-muted)] focus:outline-none py-3"
            />
          </div>
          <div class="border-b border-black/15 pb-1">
            <label class="sr-only" for="f-prestation">Prestation</label>
            <select
              id="f-prestation"
              name="Prestation"
              required
              class="w-full bg-transparent text-[14px] tracking-[0.02em] text-[var(--color-muted)] focus:outline-none py-3 appearance-none"
            >
              <option value="" disabled selected>PRESTATION SOUHAITÉE *</option>
              <option>L'Exception — Design Intégral</option>
              <option>Décor &amp; Identité Visuelle</option>
              <option>Décor &amp; Mise en Ambiance</option>
              <option>L'Art Floral</option>
              <option>Papeterie Fine</option>
              <option>Sur-mesure</option>
            </select>
          </div>
          <div class="border-b border-black/15 pb-1">
            <label class="sr-only" for="f-type">Type d'évènement</label>
            <select
              id="f-type"
              name="Type"
              required
              class="w-full bg-transparent text-[14px] tracking-[0.02em] text-[var(--color-muted)] focus:outline-none py-3 appearance-none"
            >
              <option value="" disabled selected>TYPE D'ÉVÈNEMENT *</option>
              <option>Mariage</option>
              <option>Anniversaire</option>
              <option>Baby Shower</option>
              <option>Évènement Corporate</option>
              <option>Autre</option>
            </select>
          </div>
          <div class="border-b border-black/15 pb-1">
            <label class="sr-only" for="f-budget">Budget</label>
            <input
              id="f-budget"
              type="text"
              name="Budget"
              required
              placeholder="BUDGET ENVISAGÉ POUR VOTRE PROJET *"
              class="w-full bg-transparent text-[14px] tracking-[0.02em] placeholder:text-[12px] placeholder:tracking-[0.22em] placeholder:uppercase placeholder-[var(--color-muted)] focus:outline-none py-3"
            />
          </div>
          <div class="border-b border-black/15 pb-1">
            <label class="sr-only" for="f-desc">Description</label>
            <textarea
              id="f-desc"
              name="Description"
              required
              rows="4"
              placeholder="DESCRIPTION *"
              class="w-full bg-transparent text-[14px] tracking-[0.02em] placeholder:text-[12px] placeholder:tracking-[0.22em] placeholder:uppercase placeholder-[var(--color-muted)] focus:outline-none py-3 resize-none"
            ></textarea>
          </div>

          <div class="pt-4 text-center md:text-right">
            <button
              type="submit"
              class="font-script text-[44px] md:text-[56px] text-[var(--color-ink)] hover:opacity-70 transition leading-none"
            >
              Envoyer
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>
