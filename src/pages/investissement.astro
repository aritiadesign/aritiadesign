---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import SparkLink from "../components/SparkLink.astro";
import MediaCard from "../components/MediaCard.astro";
import PackCard from "../components/PackCard.astro";

const services = [
  {
    kicker: "Direction artistique",
    scriptHtml: "Direction<br />artistique",
    title: "DIRECTION",
    titleItalic: "Artistique",
    packIndex: 0,
    body: `En direction artistique globale, nous signons votre univers de manière absolue : identité graphique, art de la table, design floral, structures sur‑mesure et mise en scène. Une seule vision sur l'ensemble pour que chaque détail réponde à la même intention, sans aucun intermédiaire. Ce contrôle absolu de la chaîne de création supprime toute rupture de ton et livre l'expression exacte de votre projet. Découvrez cette approche à travers notre collection signature : <a href="#pack-0" class="underline underline-offset-4 decoration-from-font hover:opacity-70 transition">L'EXCEPTION</a>.`,
    image: "/images/services-design-global.jpg",
    alt: "Salle de réception aux baies vitrées",
  },
  {
    kicker: "Mise en ambience",
    scriptHtml: "Mise en<br />ambience",
    title: "DECOR",
    titleItalic: "Scénographie",
    packIndex: 2,
    body: `La maîtrise globale de votre décor. Nous concevons et coordonnons l'ensemble des éléments visuels de votre événement : mobilier, éclairage, matières et accessoires. Notre rôle est de garantir l'harmonie absolue de l'espace, où chaque détail visible répond à la même intention, afin que la scénographie finale soit la traduction exacte du projet initial.`,
    image: "/images/services-decor.jpg",
    alt: "Salle voûtée bois avec dressage",
  },
  {
    kicker: "Conception floral",
    scriptHtml: "Conception<br />floral",
    title: "FLORAL",
    titleItalic: "Design",
    packIndex: 3,
    body: `Du détail intime aux installations d'ampleur, nous concevons chaque pièce végétale en résonance avec votre univers visuel. Sélection rigoureuse des variétés, maîtrise des textures, des palettes et des volumes : les fleurs s'inscrivent comme une composante essentielle de la scénographie, loin du simple accessoire.`,
    image: "/images/services-papeterie.png",
    alt: "Cérémonie outdoor pampas",
  },
  {
    kicker: "Design graphique",
    scriptHtml: "Design<br />graphique",
    title: "IDENTITÉ",
    titleItalic: "Graphique",
    packIndex: 4,
    body: `L'identité graphique est le premier point de contact de votre événement. Du monogramme à la signalétique du jour J, nous dessinons un univers visuel unique : choix des typographies, illustrations exclusives, textures des papiers et finitions artisanales. Chaque pièce est pensée comme un objet d'art imprimé, pour prolonger l'esthétique de votre célébration.`,
    image: "/images/services-floral.jpg",
    alt: "Bouquet et menu de mariage",
  },
];

const packs = [
  {
    title: "L'EXCEPTION",
    italic: "Design Intégral",
    label: "COLLECTION SIGNATURE | SUR DEVIS",
    bullets: [
      "Création de votre univers et identité graphique",
      "Confection et agencement de votre décor",
      "Conceptions florales signature",
      "Mise en place et accompagnement complet",
    ],
    desc: "L'expérience la plus aboutie : vous nous confiez l'univers entier de votre célébration. Votre rôle se limite à l'approbation des concepts ; nous maîtrisons toute la chaîne de création pour vous livrer, le jour J, un décor unique et impeccable. L'assurance d'une exécution fidèle à l'intention.",
    image: "/images/services-pack-exception.jpg",
    accent: "burgundy",
  },
  {
    title: "DÉCOR & IDENTITÉ VISUELLE",
    italic: "",
    label: "SCÉNOGRAPHIE & IDENTITÉ GRAPHIQUE<br />| SUR DEVIS",
    bullets: [
      "Définition de votre style et harmonie colorée",
      "Aménagement et mise en scène des espaces clés",
      "Graphisme et supports personnalisés",
      "Coordination & installation",
    ],
    desc: "Décor et identité graphique pensés comme un ensemble : la même charte visuelle traverse l'espace et le papier, du faire‑part à la mise en scène finale. Une cohérence totale entre ce que vos invités voient, touchent et lisent le jour J. Hors production florale et structures sur‑mesure, nous orchestrons tout votre univers visuel.",
    image: "/images/services-pack-decor.jpg",
    accent: "ink",
    bgColor: "#2b2a2d",
  },
  {
    title: "DÉCOR & MISE EN AMBIANCE",
    italic: "",
    label: "DÉCOR & SCÉNOGRAPHIE | SUR DEVIS",
    bullets: [
      "Étude de style et carnet d'inspiration",
      "Agencement et sélection du mobilier",
      "Recherche de prestataires spécialisés",
      "Gestion de l'installation et du démontage",
    ],
    desc: "L'art de l'espace : nous concevons l'atmosphère, sélectionnons le mobilier comme les matières, et coordonnons les artisans pour assurer une installation millimétrée. L'alternative idéale pour maîtriser votre décor, hors identité graphique et design floral.",
    image: "/images/services-pack-mise.jpg",
    accent: "ink",
  },
  {
    title: "L'ART FLORAL",
    italic: "",
    label: "DESIGN FLORAL | SUR DEVIS",
    bullets: [
      "Étude de votre univers floral personnalisé",
      "Création de vos bouquets et accessoires",
      "Réalisation de décors monumentaux",
      "Installation et mise en fleurs le jour J",
    ],
    desc: "Bouquets, compositions, structures suspendues ou monumentales : nous prenons en charge toute la création florale de votre événement, de l'étude à la mise en place le jour J. Hors scénographie d'espace et identité graphique, le végétal est notre unique focus.",
    image: "/images/services-pack-floral.jpg",
    accent: "ink",
  },
  {
    title: "IDENTITÉ GRAPHIQUE",
    italic: "",
    label: "PAPETERIE FINE | SUR DEVIS",
    bullets: [
      "Conception de votre logo et monogramme",
      "Design de vos faire-part et annonces",
      "Création des supports de table et signalétique",
      "Conseil en matériaux et finitions d'art",
    ],
    desc: "Logos, Invitations, pièces de table, signalétique et papeterie d’art : nous prenons en charge toute l’identité graphique de votre événement, de l’étude à la livraison finale. Hors scénographie d’espace et design floral, notre intervention se consacre exclusivement au support visuel.",
    image: "/images/services-papeterie.jpg",
    accent: "ink",
  },
];

const faqs = [
  {
    n: "01.",
    q: "ÊTES-VOUS PRÉSENTS LE JOUR J ?",
    a: "Oui, pour toutes nos formules avec exécution (l'Exception et Pack Atmosphère). Nous sommes présents de l'installation au démontage J+1 : nous orchestrons l'arrivée des prestataires, supervisons la mise en place et veillons à ce que chaque détail reflète fidèlement la direction artistique imaginée ensemble. Vous vivez votre célébration sereinement, sans avoir à gérer la logistique. Pour la Direction Artistique seule, vous repartez avec notre vision et l'orchestrez avec vos propres prestataires.",
  },
  {
    n: "02.",
    q: "QUELLE EST LA DIFFÉRENCE ENTRE VOS PRESTATIONS ET CELLES D'UN WEDDING PLANNER ?",
    a: "Notre rôle couvre la création artistique de votre mariage (univers visuel, scénographie, design floral, papeterie) et la coordination des prestataires qui exécutent cette vision (mobilier, éclairage, vaisselle, location décor...), tandis que le wedding planner orchestre l'organisation globale (planning, budget, traiteur, photographe, musique, lieu...). Les deux métiers sont complémentaires : l'un assure la fluidité organisationnelle, l'autre sublime l'expérience visuelle.",
  },
  {
    n: "03.",
    q: "OÙ OPÉREZ-VOUS ?",
    a: "Notre agence est basée à Toulouse et intervient principalement en Haute-Garonne. Au-delà, nous nous déplaçons dans toute la France et à l'étranger selon les projets, avec des frais de déplacement intégrés au devis pour une totale transparence.",
  },
  {
    n: "04.",
    q: "À PARTIR DE QUAND FAUT-IL VOUS CONTACTER ?",
    a: "Idéalement, entre 8 et 12 mois avant la date de votre mariage — le temps nécessaire pour définir le concept, sélectionner les prestataires et orchestrer chaque détail. Nous restons flexibles sur des délais plus courts selon nos disponibilités du moment.",
  },
];
---

<Layout
  title="Investissement — Aritia Design Toulouse"
  description="Direction artistique, design floral, scénographie et papeterie sur-mesure pour mariages haut de gamme à Toulouse. Découvrez les packages Aritia : Moment d'Exception, Éclat Raffiné, Signature Floral."
  transparentHeader={true}
>
  <PageHero
    image="/images/services-hero.jpg"
    imageAlt="Direction artistique"
    titleHtml="Investissement"
    titleKey="services.hero.title"
    subtitleHtml="De l'inspiration à la réalisation, chaque étape est pensée <br />pour refléter votre&nbsp;univers"
    subtitleKey="services.hero.subtitle"
  />

  {/* ───────────────────────── 2. UNE DIRECTION ARTISTIQUE ───────────────────────── */}
  <section class="bg-white px-6 py-24 md:py-32 text-center">
    <h2 class="font-display font-normal text-[28px] md:text-[36px] tracking-[0.06em] leading-[1.4] text-[var(--color-ink)]" data-i18n="services.intro.h2">
      UNE DIRECTION ARTISTIQUE<br />
      POUR DONNER VIE À VOS ÉMOTIONS
    </h2>
  </section>

  {/* ───────────────────────── 3. NOTRE APPROCHE (intro) ───────────────────────── */}
  <section class="bg-white px-6 pb-20 md:pb-28">
    <div class="mx-auto max-w-[1100px] grid lg:grid-cols-2 gap-8 lg:gap-12 items-start text-center lg:text-left">
      <div>
        <h3 class="font-display text-[44px] md:text-[48px] lg:text-[60px] leading-none tracking-wide" data-i18n="services.approach.h3">
          NOTRE<br />
          <span class="font-italic-serif italic">Approche</span>
        </h3>
      </div>
      <div class="max-w-md mx-auto lg:mx-0 text-left text-pretty text-[14px] md:text-[16px] leading-[1.75] md:leading-[1.9] text-[var(--color-ink-soft)]">
        <p data-i18n="services.approach.p">
          Aritia Design pense l'évènement comme une pièce de design
          unique. Identité graphique, art de la table, design floral
          et scénographie d'espace s'orchestrent pour donner vie à
          une émotion.
        </p>
      </div>
    </div>
  </section>

  {/* ───────────────────────── 7. SERVICES — TABS DESKTOP / CARROUSEL MOBILE ───────────────────────── */}
  <section class="bg-white pt-10 md:pt-16 pb-32 md:pb-48">
    <div class="mx-auto md:w-[80%] max-w-[1300px]">
      {/* Tab bar — desktop only */}
      <div class="services-tabs-wrap relative hidden md:block">
      <div role="tablist" class="services-tabs flex flex-nowrap overflow-x-auto lg:overflow-visible gap-2 lg:gap-1 snap-x snap-proximity lg:snap-none pr-12 lg:pr-0">
        <style is:global>
          .services-tabs::-webkit-scrollbar { display: none; }
          .services-tabs { scrollbar-width: none; }
        </style>
        {services.map((s, i) => (
          <button
            type="button"
            role="tab"
            class="services-tab"
            data-tab={i}
            data-i18n={`services.tab.${i}`}
            aria-selected={i === 0 ? "true" : "false"}
          >
            ✦ {s.title}{s.titleItalic ? ` ${s.titleItalic.toUpperCase()}` : ""} ✦
          </button>
        ))}
      </div>
        {/* left-edge fade + chevron — visible once user has scrolled past the start */}
        <div class="services-scroll-hint-left pointer-events-none absolute top-0 left-0 h-full w-16 flex items-center justify-start pl-1 bg-gradient-to-r from-white via-white/85 to-transparent">
          <svg class="w-5 h-5 text-[#2b2b2b]/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 18l-6-6 6-6" />
          </svg>
        </div>
        {/* right-edge fade + bouncing chevron — hidden once scrolled to the end */}
        <div class="services-scroll-hint pointer-events-none absolute top-0 right-0 h-full w-16 flex items-center justify-end pr-1 bg-gradient-to-l from-white via-white/85 to-transparent">
          <svg class="w-5 h-5 text-[#2b2b2b]/70 animate-scroll-nudge" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M9 18l6-6-6-6" />
          </svg>
        </div>
      </div>

      {/* Mobile carousel: bound to the packs (boîtes), independent from desktop tabs */}
      <div class="md:hidden services-carousel flex overflow-x-auto snap-x snap-mandatory gap-4 px-[10vw] pb-2">
        <style is:global>
          .services-carousel::-webkit-scrollbar { display: none; }
          .services-carousel { scrollbar-width: none; -webkit-overflow-scrolling: touch; }
          .services-card { transition: opacity 0.35s ease, transform 0.35s ease; opacity: 0.55; transform: scale(0.94); transform-origin: center; }
          .services-card[data-active="true"] { opacity: 1; transform: scale(1); }
        </style>
        {packs.map((pack, i) => {
          const cardBg = pack.bgColor ?? (pack.accent === "burgundy" ? "#640613" : "#1A1A1A");
          return (
            <article
              class="services-card snap-center shrink-0 w-[80vw] text-white overflow-hidden flex flex-col"
              style={`background-color: ${cardBg};`}
              data-active={i === 0 ? "true" : "false"}
            >
              <div class="relative aspect-[4/3] overflow-hidden">
                <img src={pack.image} alt={pack.title} class="absolute inset-0 w-full h-full object-cover" />
              </div>
              <div class="p-8 flex flex-col flex-1">
                <h3 class:list={["font-display leading-[1.1] tracking-wide min-h-[80px]", (i === 1 || i === 2) ? "text-[26px] leading-[1.15]" : "text-[34px]"]}>
                  <span data-i18n={`services.pack.${i}.title`}>
                    {pack.title.split("&").map((part, idx, arr) => (
                      <>{part}{idx < arr.length - 1 && <span class="amp">&amp;</span>}</>
                    ))}
                  </span>
                  {pack.italic && <> <span class="font-italic-serif italic font-light" data-i18n={`services.pack.${i}.italic`}>{pack.italic}</span></>}
                </h3>
                <p class="mt-6 text-[15px] leading-[1.7] text-white min-h-[280px]" data-i18n={`services.pack.${i}.desc`}>{pack.desc}</p>
                <details class="group mt-6 border-t border-white/15 pt-4">
                  <summary class="cursor-pointer list-none flex items-center justify-between gap-3 text-[12px] tracking-[0.2em] uppercase text-white/90">
                    <span class="whitespace-nowrap" data-i18n="services.included">✦ Compris dans l'expérience</span>
                    <span class="text-[18px] leading-none transition-transform group-open:rotate-45">+</span>
                  </summary>
                  <ul class="mt-4 space-y-2.5 text-[15px] leading-[1.5] text-white">
                    {pack.bullets.map((b, idx) => (
                      <li class="flex gap-3 items-start">
                        <span aria-hidden="true" class="inline-block w-[6px] h-[6px] rounded-full bg-current mt-[9px] shrink-0"></span>
                        <span data-i18n={`services.pack.${i}.b${idx}`}>{b}</span>
                      </li>
                    ))}
                  </ul>
                  <p class="mt-8 text-[12px] tracking-[0.2em] uppercase text-white/90 whitespace-nowrap" data-i18n="services.devisOnly">— SUR DEVIS UNIQUEMENT</p>
                </details>
              </div>
            </article>
          );
        })}
      </div>

      {/* Mobile-only shared CTA below the carousel */}
      <div class="md:hidden mt-10 px-6 flex justify-center">
        <a
          href="/contact"
          class="inline-block px-10 py-4 border border-[var(--color-ink)] text-[12px] tracking-[0.32em] uppercase hover:bg-[var(--color-ink)] hover:text-white transition"
          data-i18n="services.cta.mobile"
        >
          Prendre rendez-vous
        </a>
      </div>

      {/* Desktop tab panels */}
      {services.map((s, i) => (
        <div role="tabpanel" class="services-panel hidden md:block" data-panel={i} hidden={i !== 0}>
          <MediaCard image={s.image} imageAlt={s.alt}>
            <h3 class="font-display text-[48px] leading-[1] tracking-wide" data-i18n={`services.${i}.title`}>
              {s.title.split("&").map((part, i, arr) => (
                <>{part}{i < arr.length - 1 && <span class="amp">&amp;</span>}</>
              ))}
              {s.titleItalic && <> <span class="font-italic-serif italic font-light">{s.titleItalic}</span></>}
            </h3>
            <div class="mt-20 text-[16px] leading-[1.9] text-white max-w-md space-y-4" data-i18n={`services.${i}.body`} set:html={s.body.split("\n\n").map((p) => `<p>${p}</p>`).join("")} />
            <SparkLink href="/contact" label="Prendre rendez-vous" i18nKey="services.cta.tab" arrowClass="h-[22px] w-[22px] lg:h-[37px] lg:w-[37px]" class="mt-auto pt-10 self-start whitespace-nowrap !text-[13px] lg:!text-[18px] !tracking-[0.18em] lg:!tracking-[0.2em] !gap-2 lg:!gap-3" />
          </MediaCard>
        </div>
      ))}
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>(".services-tabs").forEach((bar) => {
      const tabs = bar.querySelectorAll<HTMLButtonElement>(".services-tab");
      const panels = bar.closest("section")!.querySelectorAll<HTMLElement>(".services-panel");
      tabs.forEach((tab) =>
        tab.addEventListener("click", () => {
          const idx = tab.dataset.tab;
          tabs.forEach((t) => t.setAttribute("aria-selected", t === tab ? "true" : "false"));
          panels.forEach((p) => { p.hidden = p.dataset.panel !== idx; });
        })
      );
    });

    // Mobile carousel: mark the card whose center is closest to the viewport center as active.
    const carousel = document.querySelector<HTMLElement>(".services-carousel");
    if (carousel) {
      const cards = Array.from(carousel.querySelectorAll<HTMLElement>(".services-card"));
      const update = () => {
        const carouselRect = carousel.getBoundingClientRect();
        const centerX = carouselRect.left + carouselRect.width / 2;
        let bestIdx = 0;
        let bestDelta = Infinity;
        cards.forEach((card, i) => {
          const rect = card.getBoundingClientRect();
          const cardCenter = rect.left + rect.width / 2;
          const delta = Math.abs(cardCenter - centerX);
          if (delta < bestDelta) { bestDelta = delta; bestIdx = i; }
        });
        cards.forEach((c, i) => c.setAttribute("data-active", i === bestIdx ? "true" : "false"));
      };
      carousel.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);
      update();
    }

    // Desktop tabs: hide the scroll-hint chevron once user has scrolled to the end
    // (or when there's no overflow at all).
    document.querySelectorAll<HTMLElement>(".services-tabs-wrap").forEach((wrap) => {
      const bar = wrap.querySelector<HTMLElement>(".services-tabs");
      if (!bar) return;
      const updateHint = () => {
        const overflow = bar.scrollWidth - bar.clientWidth;
        const atStart = bar.scrollLeft <= 2;
        const atEnd = overflow <= 1 || bar.scrollLeft >= overflow - 2;
        wrap.dataset.start = atStart ? "true" : "false";
        wrap.dataset.end = atEnd ? "true" : "false";
      };
      bar.addEventListener("scroll", updateHint, { passive: true });
      window.addEventListener("resize", updateHint);
      updateHint();
    });
  </script>

  <style>
    .services-tabs {
      position: relative;
    }
    @keyframes scroll-nudge {
      0%, 100% { transform: translateX(0); opacity: 0.7; }
      50% { transform: translateX(4px); opacity: 1; }
    }
    .animate-scroll-nudge {
      animation: scroll-nudge 1.4s ease-in-out infinite;
    }
    .services-scroll-hint,
    .services-scroll-hint-left {
      transition: opacity 0.25s ease;
    }
    .services-scroll-hint-left {
      opacity: 0;
    }
    .services-tabs-wrap[data-start="false"] .services-scroll-hint-left {
      opacity: 1;
    }
    .services-tabs-wrap[data-end="true"] .services-scroll-hint {
      opacity: 0;
    }
    .services-tab {
      background-color: rgba(43, 42, 45, 0.1);
      color: #2b2a2d;
      padding: 12px 14px;
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      border-top-left-radius: 6px;
      border-top-right-radius: 6px;
      cursor: pointer;
      transition: background-color 0.2s, color 0.2s;
      white-space: nowrap;
      scroll-snap-align: start;
      flex-shrink: 0;
    }
    @media (min-width: 768px) {
      .services-tab {
        font-size: 15px;
        padding: 16px 20px;
      }
    }
    @media (min-width: 1024px) {
      .services-tab {
        flex: 1 1 0;
        min-width: 0;
        text-align: center;
        font-size: 10px;
        padding: 14px 4px;
        letter-spacing: 0.1em;
        scroll-snap-align: none;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .services-scroll-hint,
      .services-scroll-hint-left {
        display: none !important;
      }
    }
    @media (min-width: 1280px) {
      .services-tab {
        font-size: 11px;
        padding: 16px 6px;
        letter-spacing: 0.14em;
      }
    }
    @media (min-width: 1440px) {
      .services-tab {
        font-size: 12px;
        padding: 16px 8px;
        letter-spacing: 0.18em;
      }
    }
    .services-tab:hover {
      background-color: rgba(43, 42, 45, 0.2);
    }
    .services-tab[aria-selected="true"] {
      background-color: #1A1A1A;
      color: #fff;
    }
    .services-parallax {
      height: 460px;
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
    }
    @media (max-width: 767px) {
      .services-parallax { height: 280px; background-attachment: scroll; }
    }
  </style>

  {/* ───────────────────────── 7b. PARALLAX IMAGE BREAK ───────────────────────── */}
  <section
    class="services-parallax"
    aria-label="Détails de table"
    style="background-image: url('/images/services-intro.jpg');"
  ></section>

  {/* ───────────────────────── 8. PACKS & FORMULES (header) — hidden on mobile ───────────────────────── */}
  <section class="hidden md:block bg-white px-6 pt-24 md:pt-32 pb-12 md:pb-16 text-center">
    <div class="inline-block px-8 py-3 bg-[#1a1a1a] text-white text-[11px] tracking-[0.32em] uppercase" data-i18n="services.packs.header">
      ✦ Packs &amp; Formules ✦
    </div>
    <h2 class="mt-12 font-display font-normal text-[40px] md:text-[52px] lg:text-[64px] leading-[1.1] text-[var(--color-ink)]" data-i18n="services.packs.h2">
      L'<span>ÉLÉGANCE</span>
      <span class="font-italic-serif italic font-light">sur-mesure</span><br />
      <span class="font-italic-serif italic font-light">à votre</span>
      <span>IMAGE</span>
    </h2>
    <p class="mt-10 text-[16px] leading-[1.9] text-[var(--color-ink-soft)] max-w-xl mx-auto" data-i18n="services.packs.intro">
      Chaque projet est unique, c'est pourquoi mes prestations
      s'articulent autour de packages sur-mesure et de formules
      personnalisables.
    </p>
  </section>

  {/* ───────────────────────── 9. PACK CARDS — hidden on mobile ───────────────────────── */}
  <section class="hidden md:block bg-white px-6 pb-24 md:pb-32 space-y-16 md:space-y-20 lg:space-y-28">
    {packs.map((p, i) => (
      <div id={`pack-${i}`} class:list={["mx-auto w-[90%] md:w-[85%] lg:w-[80%] max-w-[1300px] scroll-mt-32", (i === 1 || i === 2) ? "!mt-24 md:!mt-32 lg:!mt-56" : ""]}>
        <PackCard
          image={p.image}
          title={p.title}
          italic={p.italic}
          label={p.label}
          bullets={p.bullets}
          desc={p.desc}
          accent={p.accent === "burgundy" ? "burgundy" : "dark"}
          bgColor={p.bgColor}
          watermark={p.accent === "burgundy" ? "/images/services-pack-bg.png" : undefined}
          i18nPrefix={`services.pack.${i}`}
        />
      </div>
    ))}
  </section>

  {/* ───────────────────────── 10. UN MOMENT D'EXCEPTION (intro video) ───────────────────────── */}
  <section class="bg-white px-6 py-20 md:py-28 text-center">
    <h2 class="font-display text-[36px] md:text-[44px] lg:text-[52px] leading-[1.2]" data-i18n="services.moment.h2">
      UN MOMENT D'EXCEPTION&nbsp;!<br />
      <span class="font-italic-serif italic text-[0.7em]">décor, mise en ambiance, papeterie, floral</span>
    </h2>

    <div class="mt-12 md:mt-16 mx-auto max-w-[1100px]">
      <video
        class="block w-full aspect-video bg-black"
        src="/videos/clip-intro.mp4"
        controls
        playsinline
        preload="metadata"
        poster="/images/hero-poster.jpg"
      ></video>
    </div>

    {/* Desktop-only S'INSPIRER CTA — right-aligned to the video's right edge */}
    <div class="hidden md:flex justify-end mt-10 mx-auto max-w-[1100px]">
      <SparkLink href="/portfolio" label="S'inspirer" i18nKey="services.moment.cta" />
    </div>
  </section>

  {/* ───────────────────────── 11. VOTRE UNIVERS CTA ───────────────────────── */}
  <section class="bg-[#1a1a1a] text-white px-6 py-24 md:py-32 text-center">
    <h2 class="font-display text-[36px] md:text-[44px] lg:text-[52px] leading-[1.2]" data-i18n="services.final.h2">
      VOTRE UNIVERS, VOTRE HISTOIRE,<br />
      <span class="font-italic-serif italic">une création unique</span>
    </h2>
    <p class="mt-6 md:mt-8 text-[13px] md:text-[16px] tracking-[0.22em] md:tracking-[0.28em] uppercase text-white/85" data-i18n="services.final.sub">
      Ensemble, donnons-lui vie
    </p>
    <a
      href="/contact"
      class="inline-block mt-12 px-12 py-4 bg-[var(--color-burgundy)] text-white text-[0.72rem] tracking-[0.32em] uppercase hover:bg-[var(--color-burgundy-dark)] transition"
      data-i18n="services.final.cta"
    >
      Me contacter
    </a>
  </section>

  {/* ───────────────────────── 12. FAQ ───────────────────────── */}
  <section class="bg-white px-6 py-24 md:py-32">
    <h2 class="text-center font-display text-[28px] md:text-[36px] tracking-[0.28em] uppercase text-[var(--color-ink)] mb-16" data-i18n="services.faq.h2">
      Questions Fréquentes
    </h2>
    <div class="mx-auto max-w-[900px] divide-y divide-black/10">
      {faqs.map((f, i) => (
        <details class="group py-6">
          <summary class="cursor-pointer list-none flex items-start gap-6">
            <span class="font-display text-[20px] md:text-[26px] text-[var(--color-ink-soft)] shrink-0">{f.n}</span>
            <span class="flex-1 text-[12px] md:text-[14px] tracking-[0.22em] uppercase leading-[1.6] text-[var(--color-ink)]" data-i18n={`services.faq.${i}.q`}>
              {f.q}
            </span>
            <span class="shrink-0 mt-1 transition-transform group-open:rotate-45 text-[24px] text-[var(--color-ink-soft)] leading-none">+</span>
          </summary>
          <p class="mt-4 pl-[3.5rem] text-[14px] leading-[1.9] text-[var(--color-ink-soft)]" data-i18n={`services.faq.${i}.a`} set:html={f.a} />
        </details>
      ))}
    </div>
  </section>
</Layout>
