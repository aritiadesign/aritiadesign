---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  /** When true, the header sits over the hero with white text. */
  transparentHeader?: boolean;
  /** When false, render the footer in light theme (white bg). */
  darkFooter?: boolean;
}

const {
  title = "ACCUEIL | Aritia Design",
  description = "Créatrice d'univers évènementiels haut de gamme à Toulouse — design floral, scénographie et papeterie pour mariages et événements d'exception.",
  transparentHeader = true,
  darkFooter = true,
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL("/og-image.jpg", Astro.site ?? Astro.url).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="fr_FR" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL("/og-image.jpg", Astro.site ?? Astro.url).toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="preload" href="/fonts/PlayfairDisplay.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Raleway.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/HauteCouture.otf" as="font" type="font/otf" crossorigin />
    <title>{title}</title>
  </head>
  <body class="bg-white text-[var(--color-ink)] antialiased">
    <Header transparent={transparentHeader} />
    <main>
      <slot />
    </main>
    <Footer dark={darkFooter} />

    <script>
      // iOS Safari autoplay fix — set muted explicitly via JS and retry on first user gesture.
      const startVideos = () => {
        document.querySelectorAll<HTMLVideoElement>("video[autoplay]").forEach((v) => {
          v.muted = true;
          v.setAttribute("muted", "");
          v.setAttribute("playsinline", "");
          v.setAttribute("webkit-playsinline", "");
          const p = v.play();
          if (p && typeof p.catch === "function") p.catch(() => {});
        });
      };
      startVideos();
      const retry = () => {
        startVideos();
        window.removeEventListener("touchstart", retry);
        window.removeEventListener("click", retry);
      };
      window.addEventListener("touchstart", retry, { passive: true, once: true });
      window.addEventListener("click", retry, { once: true });
    </script>
  </body>
</html>
