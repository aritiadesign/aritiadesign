---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { i18n } from "../data/i18n";

interface Props {
  title?: string;
  description?: string;
  /** Comma-separated keywords. Empty by default — Google ignores `keywords` anyway, but Bing still reads it. */
  keywords?: string;
  /** When true, the header sits over the hero with white text. */
  transparentHeader?: boolean;
  /** When true, the solid header renders dark (#1a1a1a bg + white text). Ignored if transparentHeader is true. */
  darkHeader?: boolean;
  /** When false, render the footer in light theme (white bg). */
  darkFooter?: boolean;
}

const {
  title = "Décoration mariage Toulouse, Haute-Garonne | Aritia Design",
  description = "Décoration de mariage haut de gamme Toulouse (Haute-Garonne). Aritia Design transforme chaque occasion en moment d'exception en alliant design floral, scénographie et papeterie sur-mesure.",
  keywords = "décoratrice de mariage Toulouse, décoratrice de mariage Haute-Garonne, décoratrice de mariage Occitanie, décoratrice de mariage Sud-Ouest, décoratrice de mariage France, décoratrice mariage haut de gamme, décoratrice mariage de luxe, décoratrice événements Toulouse, Aritia Design, Aritia, mariage haut de gamme, mariage de luxe, mariage d'exception, scénographie mariage, design floral mariage, papeterie mariage sur-mesure, wedding designer Toulouse, wedding planner Toulouse, créatrice de mariages, direction artistique mariage, mariage Occitanie, mariage Sud de la France",
  transparentHeader = true,
  darkHeader = false,
  darkFooter = true,
} = Astro.props;

const siteOrigin = Astro.site?.toString() ?? "https://aritiadesign.com";
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const ogImageURL = new URL("/og-image.jpg", Astro.site ?? Astro.url).toString();
const logoURL = new URL("/favicon.svg", Astro.site ?? Astro.url).toString();

// BreadcrumbList — auto-generated from the URL path.
const breadcrumbLabels: Record<string, string> = {
  "a-propos": "À propos",
  "services": "Services & tarifs",
  "processus": "Processus créatif",
  "contact": "Contact",
  "portfolio": "Portfolio",
  "mentions-legales": "Mentions légales",
  "politique-confidentialite": "Politique de confidentialité",
};
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbItems = [
  { name: "Accueil", url: siteOrigin },
  ...pathSegments.map((seg, i) => ({
    name: breadcrumbLabels[seg] ?? seg.replace(/-/g, " "),
    url: `${siteOrigin}${pathSegments.slice(0, i + 1).join("/")}/`,
  })),
];
const breadcrumbSchema = breadcrumbItems.length > 1 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    "item": item.url,
  })),
} : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": ["ProfessionalService", "LocalBusiness"],
  "@id": `${siteOrigin}#organization`,
  "name": "Aritia Design",
  "alternateName": ["Aritia", "Agence Aritia", "Aritia Wedding Design", "Aritia Wedding & Event Design"],
  "slogan": "Wedding & Event Designer",
  "disambiguatingDescription": "Aritia Design est une agence de wedding & event designer spécialisée en décoration de mariage et d'événements haut de gamme, basée à Toulouse, en Haute-Garonne. À ne pas confondre avec la marque de prêt-à-porter canadienne Aritzia.",
  "image": ogImageURL,
  "logo": logoURL,
  "url": siteOrigin,
  "description": "Aritia Design est une agence de wedding & event designer qui conçoit la décoration de mariage et d'événements haut de gamme depuis Toulouse en Haute-Garonne, pour particuliers et professionnels, en alliant direction artistique, scénographie, design floral et papeterie sur-mesure pour des célébrations d'exception.",
  "founder": {
    "@type": "Person",
    "name": "Aritia"
  },
  "serviceType": [
    "Wedding design",
    "Event design",
    "Direction artistique événementielle",
