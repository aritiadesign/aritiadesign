---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { i18n } from "../data/i18n";

interface Props {
  title?: string;
  description?: string;
  /** Comma-separated keywords. Empty by default — Google ignores `keywords` anyway, but Bing still reads it. */
  keywords?: string;
  /** When true, the header sits over the hero with white text. */
  transparentHeader?: boolean;
  /** When false, render the footer in light theme (white bg). */
  darkFooter?: boolean;
}

const {
  title = "Aritia Design — Wedding & Event Designer | France",
  description = "Basée à Toulouse, l'agence Aritia Design conçoit vos mariages et évènements d'exception partout en France. Direction artistique, scénographie immersive, design floral et papeterie sur-mesure.",
  keywords = "Aritia Design, Aritia, agence Aritia, wedding designer France, wedding designer Toulouse, event designer France, mariage haut de gamme, mariage de luxe, mariage d'exception, scénographie mariage, décoration mariage France, design floral mariage, papeterie mariage sur-mesure, wedding planner Toulouse, agence évènementielle luxe, créatrice de mariages, direction artistique mariage, mariage Occitanie, mariage Sud de la France",
  transparentHeader = true,
  darkFooter = true,
} = Astro.props;

const siteOrigin = Astro.site?.toString() ?? "https://aritiadesign.com";
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const ogImageURL = new URL("/og-image.jpg", Astro.site ?? Astro.url).toString();
const logoURL = new URL("/favicon.svg", Astro.site ?? Astro.url).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${siteOrigin}#organization`,
  "name": "Aritia Design",
  "alternateName": ["Aritia", "Agence Aritia", "Aritia Wedding Design", "Aritia Wedding & Event Design"],
  "slogan": "Wedding & Event Designer",
  "disambiguatingDescription": "Aritia Design est une agence française de wedding & event design basée à Toulouse. À ne pas confondre avec la marque de prêt-à-porter canadienne Aritzia.",
  "image": ogImageURL,
  "logo": logoURL,
  "url": siteOrigin,
  "description": "Aritia Design est une agence française de wedding & event design basée à Toulouse. Nous intervenons partout en France pour concevoir des mariages et évènements haut de gamme : direction artistique, scénographie, design floral et papeterie sur-mesure.",
  "founder": {
    "@type": "Person",
    "name": "Aritia"
  },
  "serviceType": [
    "Wedding design",
    "Event design",
    "Direction artistique évènementielle",
    "Scénographie de mariage",
    "Design floral",
    "Papeterie de mariage sur-mesure"
  ],
  "areaServed": [
    { "@type": "Country", "name": "France" },
    { "@type": "AdministrativeArea", "name": "Occitanie" },
    { "@type": "AdministrativeArea", "name": "Haute-Garonne" },
    { "@type": "City", "name": "Toulouse" }
  ],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Toulouse",
    "addressRegion": "Haute-Garonne",
    "addressCountry": "FR"
  },
  "sameAs": [
    "https://www.instagram.com/aritia_design/",
    "https://www.pinterest.com/aritiadesign/"
  ],
  "knowsAbout": [
    "Wedding design",
    "Event design",
    "Scénographie évènementielle",
    "Design floral",
    "Papeterie de mariage",
    "Direction artistique",
    "Mariage haut de gamme",
    "Évènement de luxe"
  ],
  "priceRange": "€€€"
};
---

<!doctype html>
<html lang="fr" data-lang="fr">
  <head>
    <script is:inline>
      // Apply persisted language before paint so EN visitors don't flash French content.
      try {
        const saved = localStorage.getItem("lang");
        if (saved === "en") {
          document.documentElement.lang = "en";
          document.documentElement.dataset.lang = "en";
        }
      } catch (e) {}
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <meta name="author" content="Aritia Design" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Aritia Design" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Aritia Design — agence française de wedding & event design" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:locale:alternate" content="en_US" />

    <meta name="application-name" content="Aritia Design" />
    <meta name="apple-mobile-web-app-title" content="Aritia Design" />
    <meta name="p:domain_verify" content="2fbeefb26308680a01fbca4b48193ef9" />

    <link rel="alternate" hreflang="fr-FR" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=2" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png?v=2" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <link rel="preload" href="/fonts/PlayfairDisplay.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/Raleway.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/HauteCouture.otf" as="font" type="font/otf" crossorigin />
    <link rel="preload" href="/fonts/CormorantGaramond-Italic.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/EBGaramond-Italic.woff" as="font" type="font/woff" crossorigin />
    <link rel="preload" href="/fonts/Lora-Italic.woff" as="font" type="font/woff" crossorigin />
    <link rel="preload" href="/fonts/Spectral-Italic.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/CrimsonPro-Italic.woff" as="font" type="font/woff" crossorigin />
    <link rel="preload" href="/fonts/LibreBaskerville-Italic.woff" as="font" type="font/woff" crossorigin />
    <link rel="preload" href="/fonts/Serif12Beta-Italic.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/GildaDisplay-Regular.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="preload" href="/fonts/BrandonGrotesque-Medium.otf" as="font" type="font/otf" crossorigin />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VWMI5YY7SS"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-VWMI5YY7SS');
    </script>

    <title>{title}</title>
  </head>
  <body class="bg-white text-[var(--color-ink)] antialiased">
    <Header transparent={transparentHeader} />
    <main>
      <slot />
    </main>
    <Footer dark={darkFooter} />

    <script type="application/json" id="i18n-data" set:html={JSON.stringify(i18n)}></script>

    <script is:inline>
      // Language toggle — swap text and attributes for elements tagged with
      // data-i18n / data-i18n-attr, persist preference in localStorage.
      (function () {
        const i18nEl = document.getElementById("i18n-data");
        if (!i18nEl) { console.warn("[i18n] dictionary script not found"); return; }
        let dict;
        try { dict = JSON.parse(i18nEl.textContent || "{}"); }
        catch (e) { console.error("[i18n] failed to parse dictionary", e); return; }

        const applyLang = (lang) => {
          document.documentElement.lang = lang;
          document.documentElement.dataset.lang = lang;
          document.querySelectorAll("[data-i18n]").forEach((el) => {
            const key = el.getAttribute("data-i18n");
            const entry = dict[key];
            if (entry && entry[lang] !== undefined) {
              el.innerHTML = entry[lang];
            }
          });
          document.querySelectorAll("[data-i18n-attr]").forEach((el) => {
            el.getAttribute("data-i18n-attr").split(",").forEach((pair) => {
              const parts = pair.split(":").map((s) => s.trim());
              const attr = parts[0], key = parts[1];
              const entry = dict[key];
              if (entry && entry[lang] !== undefined) {
                el.setAttribute(attr, entry[lang]);
              }
            });
          });
          document.querySelectorAll("[data-lang-toggle]").forEach((btn) => {
            btn.setAttribute("aria-checked", lang === "en" ? "true" : "false");
            btn.setAttribute("aria-label", lang === "fr" ? "Switch to English" : "Passer en français");
          });
          try { localStorage.setItem("lang", lang); } catch (e) {}
        };

        const initial = document.documentElement.dataset.lang || "fr";
        if (initial === "en") applyLang("en");

        document.querySelectorAll("[data-lang-toggle]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const cur = document.documentElement.dataset.lang || "fr";
            applyLang(cur === "fr" ? "en" : "fr");
          });
        });
      })();
    </script>

    <script>
      // iOS Safari autoplay fix — set muted explicitly via JS and retry on first user gesture.
      const startVideos = () => {
        document.querySelectorAll<HTMLVideoElement>("video[autoplay]").forEach((v) => {
          v.muted = true;
          v.setAttribute("muted", "");
          v.setAttribute("playsinline", "");
          v.setAttribute("webkit-playsinline", "");
          const p = v.play();
          if (p && typeof p.catch === "function") p.catch(() => {});
        });
      };
      startVideos();
      const retry = () => {
        startVideos();
        window.removeEventListener("touchstart", retry);
        window.removeEventListener("click", retry);
      };
      window.addEventListener("touchstart", retry, { passive: true, once: true });
      window.addEventListener("click", retry, { once: true });

      // Image protection — block right-click "Save image as" and drag-to-save on images.
      const isImg = (t: EventTarget | null) =>
        t instanceof HTMLElement && t.tagName === "IMG";
      document.addEventListener("contextmenu", (e) => {
        if (isImg(e.target)) e.preventDefault();
      });
      document.addEventListener("dragstart", (e) => {
        if (isImg(e.target)) e.preventDefault();
      });
    </script>
  </body>
</html>
